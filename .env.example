# Public build-time vars (Astro reads PUBLIC_* via import.meta.env.*).
# Copy this file to .env (gitignored) and fill in real values to enable
# the corresponding optional features.

# Direct-booking promo code. When set, a quiet "Direct booking benefit"
# ribbon renders above the BookingInquiry form on the home and contact
# pages (see src/components/sections/BookingOffer.astro).
# When unset, the ribbon is not rendered at all.
# Confirm with the owner before enabling — never publish an expired offer.
PUBLIC_OFFER_CODE=
