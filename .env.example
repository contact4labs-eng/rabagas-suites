# Rabagas environment template. Two surfaces:
#
# (A) BUILD-TIME (Astro) — copy this file to `.env` (gitignored).
#     Variables prefixed PUBLIC_* are inlined into client bundles by Vite
#     at build time. Anything without the PUBLIC_ prefix is build-time only
#     for the Node process running `astro build`.
#
# (B) CLOUDFLARE WORKERS RUNTIME — set as Worker secrets in the Cloudflare
#     dashboard (Production / Staging) OR via `.dev.vars` (gitignored) for
#     `wrangler dev` and `npm run preview`. These reach the request handler
#     via `import { env } from 'cloudflare:workers'` in
#     `src/pages/api/inquiry.ts`. NEVER set them in this file — they would
#     be committed.

# ─── (A) BUILD-TIME ────────────────────────────────────────────────────

# Direct-booking promo code. When set, a quiet "Direct booking benefit"
# ribbon renders above BookingInquiry on home and contact (see
# src/components/sections/BookingOffer.astro). When unset, the ribbon is
# not rendered at all. Confirm with the owner before enabling — never
# publish an expired offer.
PUBLIC_OFFER_CODE=

# ─── (B) CLOUDFLARE WORKERS RUNTIME — for reference only ──────────────
# Do NOT set these in .env. Set in .dev.vars locally or in the Cloudflare
# dashboard for production. Documented here so deploys don't miss them.
#
# RESEND_API_KEY              [REQUIRED IN PRODUCTION]
#   Resend.com API key used by /api/inquiry to send booking + contact
#   form emails. If unset in production, /api/inquiry returns HTTP 500
#   with `errors:["service_unconfigured"]` and the visitor sees the
#   premium error UI (premium-fail-closed). Configure at:
#     Cloudflare → Workers → rabagas-suites → Settings → Variables.
#
# EMAIL_TO                    [OPTIONAL]
#   Destination address for form notifications. Defaults to
#   info@rabagas-suites.gr.
#
# ALLOW_INQUIRY_FALLBACK      [LOCAL DEV ONLY]
#   When `true` AND RESEND_API_KEY is unset, /api/inquiry logs the
#   submission to stdout and returns ok:true so local UX iteration
#   works without burning Resend quota. NEVER set this in production.
#   In `.dev.vars`:
#     ALLOW_INQUIRY_FALLBACK="true"
