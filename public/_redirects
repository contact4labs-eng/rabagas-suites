# ─── WP backend / account residue → safe destinations ────────────────
# The old theme exposed login / register / lost-password URLs that have
# no equivalent on the new site. Bounce them to home; do not 404 (would
# leak the implementation detail that we ran on WordPress).
/wp-login.php          /     301
/wp-admin              /     301
/wp-admin/             /     301
/login                 /     301
/register              /     301
/lost-password         /     301
/my-account            /     301
/my-account/           /     301
