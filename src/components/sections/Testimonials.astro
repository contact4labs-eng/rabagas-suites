---
import type { Locale } from '../../lib/i18n';
import { t } from '../../lib/i18n';
import { testimonials } from '../../data/testimonials';
import TestimonialCard from '../ui/TestimonialCard.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="bg-charcoal px-5 py-24 text-white md:py-32 lg:px-8" aria-labelledby="testimonials-heading">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 flex flex-col items-center gap-6 text-center md:flex-row md:items-end md:justify-between md:text-left" data-reveal>
      <div>
        <span class="label-uppercase mb-3 block text-stone-400">{t('section.testimonials', locale)}</span>
        <h2 class="font-heading text-4xl font-light text-white md:text-5xl" id="testimonials-heading">
          {locale === 'en' ? 'What our guests say' : '\u03A4\u03B9 \u03BB\u03AD\u03BD\u03B5 \u03BF\u03B9 \u03B5\u03C0\u03B9\u03C3\u03BA\u03AD\u03C0\u03C4\u03B5\u03C2 \u03BC\u03B1\u03C2'}
        </h2>
      </div>
      <!-- Guest reviews sourced from rabagas-suites.com testimonials section -->
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-2" data-reveal-stagger>
      {testimonials.slice(0, 4).map((item) => (
        <TestimonialCard testimonial={item} locale={locale} />
      ))}
    </div>
  </div>
</section>
