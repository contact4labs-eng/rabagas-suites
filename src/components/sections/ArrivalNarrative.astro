---
/**
 * ARRIVAL NARRATIVE — The destination story section
 * Positioned immediately after hero.
 * Creates emotional desire for Apollonia, Sifnos, and the Rabagas experience.
 * Adapted from 21st.dev Content Default split-screen editorial pattern.
 */
import { Image } from 'astro:assets';
import type { Locale } from '../../lib/i18n';
import { propertyImages } from '../../data/images';
import { t } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<!-- Brand positioning statement -->
<section class="px-5 py-24 md:py-36 lg:px-8">
  <div class="mx-auto max-w-5xl">
    <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2 md:gap-16 lg:gap-24" data-reveal>
      <!-- Image -->
      <div class="img-zoom aspect-[3/4] overflow-hidden rounded-sm md:aspect-[2/3]" data-reveal="left">
        <Image
          src={propertyImages.detail1}
          alt={t('arrival.imageAlt', locale)}
          class="h-full w-full object-cover"
          widths={[400, 640, 800]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
          quality={75}
        />
      </div>

      <!-- Editorial copy -->
      <div data-reveal="right">
        <span class="label-uppercase mb-5 block text-stone-400">
          {t('arrival.location', locale)}
        </span>
        <h2 class="font-heading text-[clamp(1.75rem,4vw,3rem)] font-light leading-[1.1] text-ink">
          {t('arrival.heading', locale)}
        </h2>
        <div class="mt-5 h-px w-10 bg-stone-300"></div>
        <p class="mt-6 text-base leading-[1.8] text-stone-500">
          {t('arrival.body1', locale)}
        </p>
        <p class="mt-4 text-base leading-[1.8] text-stone-500">
          {t('arrival.body2', locale)}
        </p>

        <!-- Press trust -->
        <div class="mt-8 border-t border-sand-200 pt-6">
          <span class="label-uppercase text-[0.55rem] text-stone-400">
            {t('arrival.featuredIn', locale)}
          </span>
          <p class="mt-2 text-sm font-light italic text-stone-400">
            Cond&eacute; Nast Traveller &middot; Athinorama &middot; In2life
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
