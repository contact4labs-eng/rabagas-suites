---
/**
 * HOMEPAGE SIGNATURE MOMENT — Origin story
 * Sits between BrandStatement and SuitesPreview. Three editorial beats that
 * connect the Sardou play (1872) → the Sifnian journalist's magazine (1878)
 * → today's six suites beside the square that bears his nickname.
 *
 * Composition (per Plan subagent):
 * - Single centered column, max-w-2xl, py-32 md:py-44.
 * - Three beats separated by mt-10/mt-12. No image, no closing line.
 * - Word "Rabagas" in Beat 1 receives italic Cormorant emphasis (.rabagas-mark)
 *   via set:html on the translation key, so each locale controls grammar order.
 * - Reveal: data-reveal="editorial" on each beat with explicit per-beat
 *   transition-delay (0 / 280ms / 560ms) so the beats land beat-by-beat instead
 *   of cascading. Stagger pattern is intentionally different from
 *   BrandStatement's word-mask, SuitesPreview's grid stagger, and
 *   ArrivalNarrative's directional reveal — variety per the playbook rule.
 * - Desktop-only gesture: indent staircase on Beats 2 and 3 (md:pl-12 md:pl-24)
 *   for asymmetric editorial composition. Mobile is flush-left.
 * - Background: cream — matches predecessor (BrandStatement) and successor
 *   (SuitesPreview) for one continuous editorial breath.
 */
import type { Locale } from '../../lib/i18n';
import { t } from '../../lib/i18n';

interface Props { locale: Locale }
const { locale } = Astro.props;
---

<section class="bg-cream px-5 py-32 md:py-44 lg:px-8" aria-label={t('aria.originStory', locale)}>
  <div class="origin-story mx-auto max-w-2xl" data-reveal-stagger>
    <span
      class="origin-kicker label-uppercase mb-12 block text-stone-400"
      data-reveal="editorial"
    >
      {t('origin.kicker', locale)}
    </span>

    <p
      class="origin-beat origin-beat-1 mt-0 font-body text-base leading-[1.85] text-stone-600 md:text-lg"
      data-reveal="editorial"
      set:html={t('origin.beat1', locale)}
    ></p>

    <p
      class="origin-beat origin-beat-2 mt-12 font-body text-base leading-[1.85] text-stone-600 md:mt-14 md:pl-12 md:text-lg"
      data-reveal="editorial"
    >
      {t('origin.beat2', locale)}
    </p>

    <p
      class="origin-beat origin-beat-3 mt-12 font-body text-base leading-[1.85] text-stone-600 md:mt-14 md:pl-24 md:text-lg"
      data-reveal="editorial"
    >
      {t('origin.beat3', locale)}
    </p>
  </div>
</section>

<style>
  /* Italic Cormorant Garamond emphasis on "Rabagas" inside Beat 1.
     Renders at 1.15× the surrounding size, no color shift, no underline —
     a single typographic anchor the reader's eye lands on first.
     Phase 8 — PART G: when the parent OriginStory section reveals, the
     mark briefly relaxes its letter-spacing from 0.04em to 0 over 900ms
     (cinematic ease). This effect appears EXACTLY ONCE on the entire site,
     by design — no other italic Cormorant text gets it. Triggered by the
     same `.is-visible` class the IntersectionObserver adds; no extra JS,
     no sessionStorage, no subagent observer. Plays once per page-load. */
  .origin-story :global(.rabagas-mark) {
    font-family: var(--font-heading), 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.15em;
    color: var(--color-ink);
    font-feature-settings: 'liga' 1, 'kern' 1;
    letter-spacing: 0.04em;
    transition: letter-spacing 900ms var(--ease-cinematic);
    transition-delay: calc(280ms + 200ms); /* lands shortly after Beat 1's reveal */
  }
  .origin-story.is-visible :global(.rabagas-mark) {
    letter-spacing: 0;
  }

  /* Per-beat reveal timing — overrides the global 80ms cascade so each beat
     reads as its own thought (0ms, 280ms, 560ms). Scoped by .origin-beat
     so it doesn't leak to other data-reveal-stagger sections. */
  .origin-story.is-visible .origin-kicker { transition-delay: 0ms; }
  .origin-story.is-visible .origin-beat-1 { transition-delay: var(--motion-stagger-deliberate); }
  .origin-story.is-visible .origin-beat-2 { transition-delay: calc(var(--motion-stagger-deliberate) * 2); }
  .origin-story.is-visible .origin-beat-3 { transition-delay: calc(var(--motion-stagger-deliberate) * 3); }

  /* Desktop-only hairline rule along the column's left edge (kicker → Beat 3)
     reinforces the centered measure as an editorial column.
     Hidden on mobile to avoid horizontal-density collision. */
  @media (min-width: 768px) {
    .origin-story {
      position: relative;
    }
    .origin-story::before {
      content: '';
      position: absolute;
      top: 0.5rem;
      bottom: 0.5rem;
      left: -2.5rem;
      width: 1px;
      background: var(--color-sand-200);
      transform: scaleY(0);
      transform-origin: top;
      transition: transform var(--motion-cinematic) var(--ease-considered);
      transition-delay: 100ms;
    }
    .origin-story.is-visible::before {
      transform: scaleY(1);
    }
  }

  /* Reduced-motion: no stagger, no rule animation, no letter-spacing
     animation. Global motion.css suppresses the data-reveal hooks; here
     we additionally kill the ::before transform and the `.rabagas-mark`
     transition so the rule snaps in instantly and the mark renders at
     its final letter-spacing immediately. */
  @media (prefers-reduced-motion: reduce) {
    .origin-story::before {
      transform: scaleY(1) !important;
      transition: none !important;
    }
    .origin-story :global(.rabagas-mark) {
      letter-spacing: 0 !important;
      transition: none !important;
    }
    .origin-story.is-visible .origin-kicker,
    .origin-story.is-visible .origin-beat-1,
    .origin-story.is-visible .origin-beat-2,
    .origin-story.is-visible .origin-beat-3 {
      transition-delay: 0ms !important;
    }
  }
</style>
