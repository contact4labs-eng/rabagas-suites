---
/**
 * STAY EXPERIENCE — Sensory/lifestyle section
 * What a stay actually feels like. Builds desire through specificity.
 */
import type { Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const moments = locale === 'en' ? [
  { title: 'Morning', desc: 'Espresso on your private terrace. Honey from the valley. The Aegean opening up below.' },
  { title: 'Afternoon', desc: 'Barefoot on warm stone. A borrowed bicycle to a hidden beach. Return to your jacuzzi as the light softens.' },
  { title: 'Evening', desc: 'George recommends the taverna. You walk two minutes through the village. Stars appear over Artemonas.' },
] : [
  { title: '\u03A0\u03C1\u03C9\u03AF', desc: '\u0395\u03C3\u03C0\u03C1\u03AD\u03C3\u03BF \u03C3\u03C4\u03B7\u03BD \u03B9\u03B4\u03B9\u03C9\u03C4\u03B9\u03BA\u03AE \u03B2\u03B5\u03C1\u03AC\u03BD\u03C4\u03B1. \u039C\u03AD\u03BB\u03B9 \u03B1\u03C0\u03CC \u03C4\u03B7\u03BD \u03BA\u03BF\u03B9\u03BB\u03AC\u03B4\u03B1. \u03A4\u03BF \u0391\u03B9\u03B3\u03B1\u03AF\u03BF \u03B1\u03C0\u03BB\u03CE\u03BD\u03B5\u03C4\u03B1\u03B9 \u03BC\u03C0\u03C1\u03BF\u03C3\u03C4\u03AC \u03C3\u03B1\u03C2.' },
  { title: '\u0391\u03C0\u03CC\u03B3\u03B5\u03C5\u03BC\u03B1', desc: '\u039E\u03C5\u03C0\u03CC\u03BB\u03C5\u03C4\u03BF\u03B9 \u03C3\u03B5 \u03B6\u03B5\u03C3\u03C4\u03AE \u03C0\u03AD\u03C4\u03C1\u03B1. \u03A0\u03BF\u03B4\u03AE\u03BB\u03B1\u03C4\u03BF \u03C3\u03B5 \u03BA\u03C1\u03C5\u03BC\u03BC\u03AD\u03BD\u03B7 \u03C0\u03B1\u03C1\u03B1\u03BB\u03AF\u03B1. \u0395\u03C0\u03B9\u03C3\u03C4\u03C1\u03BF\u03C6\u03AE \u03C3\u03C4\u03BF \u03C4\u03B6\u03B1\u03BA\u03BF\u03CD\u03B6\u03B9 \u03BA\u03B1\u03B8\u03CE\u03C2 \u03C4\u03BF \u03C6\u03C9\u03C2 \u03B1\u03C0\u03B1\u03BB\u03CE\u03BD\u03B5\u03B9.' },
  { title: '\u0392\u03C1\u03AC\u03B4\u03C5', desc: '\u039F \u0393\u03B9\u03CE\u03C1\u03B3\u03BF\u03C2 \u03C0\u03C1\u03BF\u03C4\u03B5\u03AF\u03BD\u03B5\u03B9 \u03C4\u03B7\u03BD \u03C4\u03B1\u03B2\u03AD\u03C1\u03BD\u03B1. \u03A0\u03B5\u03C1\u03C0\u03B1\u03C4\u03AC\u03C4\u03B5 \u03B4\u03CD\u03BF \u03BB\u03B5\u03C0\u03C4\u03AC. \u0391\u03C3\u03C4\u03AD\u03C1\u03B9\u03B1 \u03C0\u03AC\u03BD\u03C9 \u03B1\u03C0\u03CC \u03C4\u03B7\u03BD \u0391\u03C1\u03C4\u03B5\u03BC\u03CE\u03BD\u03B1.' },
];
---

<section class="bg-charcoal px-5 py-24 text-white md:py-36 lg:px-8" data-reveal="slow">
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 max-w-lg" data-reveal>
      <span class="label-uppercase mb-4 block text-stone-500">
        {locale === 'en' ? 'A day at Rabagas' : '\u039C\u03AF\u03B1 \u03BC\u03AD\u03C1\u03B1 \u03C3\u03C4\u03BF Rabagas'}
      </span>
      <h2 class="font-heading text-[clamp(1.75rem,4vw,3rem)] font-light leading-[1.1] text-white">
        {locale === 'en'
          ? 'The rhythm of an island, the comfort of home'
          : '\u039F \u03C1\u03C5\u03B8\u03BC\u03CC\u03C2 \u03C4\u03BF\u03C5 \u03BD\u03B7\u03C3\u03B9\u03BF\u03CD, \u03B7 \u03AC\u03BD\u03B5\u03C3\u03B7 \u03C4\u03BF\u03C5 \u03C3\u03C0\u03B9\u03C4\u03B9\u03BF\u03CD'}
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-px overflow-hidden rounded-sm border border-white/8 bg-white/8 md:grid-cols-3" data-reveal-stagger>
      {moments.map((m) => (
        <div class="bg-charcoal p-8 md:p-10">
          <span class="label-uppercase text-[0.6rem] text-terra-500">{m.title}</span>
          <p class="mt-3 font-heading text-lg font-light leading-[1.6] text-stone-300">
            {m.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
