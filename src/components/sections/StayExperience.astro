---
/**
 * STAY EXPERIENCE — Sensory/lifestyle section
 * What a stay actually feels like. Builds desire through specificity.
 */
import type { Locale } from '../../lib/i18n';
import { t } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const moments = [
  { title: t('experience.morning.title', locale),   desc: t('experience.morning.desc', locale)   },
  { title: t('experience.afternoon.title', locale), desc: t('experience.afternoon.desc', locale) },
  { title: t('experience.evening.title', locale),   desc: t('experience.evening.desc', locale)   },
];
---

<section class="bg-charcoal px-5 py-24 text-white md:py-36 lg:px-8" data-reveal="slow">
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 max-w-lg" data-reveal>
      <span class="label-uppercase mb-4 block text-stone-500">
        {t('experience.kicker', locale)}
      </span>
      <h2 class="font-heading text-[clamp(1.75rem,4vw,3rem)] font-light leading-[1.1] text-white">
        {t('experience.heading', locale)}
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-px overflow-hidden rounded-sm border border-white/8 bg-white/8 md:grid-cols-3" data-reveal-stagger>
      {moments.map((m) => (
        <div class="bg-charcoal p-8 md:p-10">
          <span class="label-uppercase text-[0.6rem] text-terra-500">{m.title}</span>
          <p class="mt-3 font-heading text-lg font-light leading-[1.6] text-stone-300">
            {m.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
