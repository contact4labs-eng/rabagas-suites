---
/**
 * HOSTS MODULE — George & Didi.
 * Slots into the Our Story page after the existing dark "Hosts" testimonial section
 * and before <FinalCTA />. The block balances the existing typographic moment by
 * giving the property's actual humans a portrait + bio.
 *
 * If hostsPortrait === null (no real portrait sourced yet), renders a typographic
 * fallback (initials in the brand serif inside a sand-toned circle). The bio
 * keys are flagged in translations.ts as "v1 placeholder — replace with
 * property-owner-authored bio when provided."
 */
import { Image } from 'astro:assets';
import type { Locale } from '../../lib/i18n';
import { t } from '../../lib/i18n';
import { hostsPortrait } from '../../data/images';

interface Props { locale: Locale }
const { locale } = Astro.props;
---

<section class="bg-cream px-5 py-24 md:py-32 lg:px-8" aria-labelledby="hosts-heading">
  <div class="mx-auto max-w-5xl">
    <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-[1fr_1.2fr] md:gap-16 lg:gap-24">
      <!-- Portrait or typographic fallback -->
      <div class="img-zoom" data-reveal="left">
        {hostsPortrait ? (
          <Image
            src={hostsPortrait}
            alt={t('hosts.imageAlt', locale)}
            class="aspect-[3/4] w-full rounded-sm object-cover"
            widths={[400, 640, 800]}
            sizes="(max-width: 768px) 100vw, 40vw"
            loading="lazy"
            quality={80}
          />
        ) : (
          <div
            class="flex aspect-[3/4] w-full items-center justify-center rounded-sm bg-gradient-to-br from-sand-100 to-sand-200"
            aria-hidden="true"
          >
            <span class="font-heading text-[clamp(4rem,12vw,8rem)] font-light leading-none text-stone-400">
              {t('hosts.initials', locale)}
            </span>
          </div>
        )}
      </div>

      <!-- Bio -->
      <div data-reveal="right">
        <span class="label-uppercase mb-4 block text-stone-400">{t('hosts.kicker', locale)}</span>
        <h2 class="font-heading text-3xl font-light leading-[1.1] text-ink md:text-4xl" id="hosts-heading">
          {t('hosts.title', locale)}
        </h2>
        <div class="mt-4 h-px w-10 bg-stone-300"></div>
        <div class="mt-8 space-y-5 text-base leading-[1.8] text-stone-500">
          <p>{t('hosts.bio.p1', locale)}</p>
          <p>{t('hosts.bio.p2', locale)}</p>
        </div>
        <p class="mt-8 font-heading text-lg font-light italic text-stone-400">
          {t('hosts.signature', locale)}
        </p>
      </div>
    </div>
  </div>
</section>
