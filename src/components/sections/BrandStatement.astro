---
/**
 * HOMEPAGE SIGNATURE MOMENT — Scroll-linked brand statement
 * Adapted from 21st.dev: TextRevealByWord (scroll-driven word opacity reveal)
 *
 * Original uses Framer Motion useScroll + useTransform per word.
 * Adapted to CSS-only with IntersectionObserver stagger for zero-JS overhead.
 * Each word starts at opacity 0.15 and reveals to full on scroll-triggered stagger.
 *
 * This creates the "one memorable authored moment" — a large serif statement
 * that materializes word by word as you scroll past the hero.
 */
import type { Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

import { t } from '../../lib/i18n';

const statement = t('brand.statement', locale);

const words = statement.split(' ');
---

<section class="px-5 py-28 md:py-40 lg:px-8" aria-label={t('aria.brandStatement', locale)}>
  <div class="mx-auto max-w-4xl">
    <p class="brand-statement flex flex-wrap justify-center gap-x-[0.4em] gap-y-[0.15em] text-center font-heading text-[clamp(1.5rem,4vw,2.75rem)] font-light leading-[1.4] tracking-tight" data-reveal-stagger>
      {words.map((word) => (
        <span class="inline-block text-ink/15 transition-colors duration-700">{word}</span>
      ))}
    </p>
  </div>
</section>

<style>
  /* Override stagger behavior for this specific section — words reveal to full color */
  .brand-statement.is-visible > span {
    color: var(--color-ink) !important;
    opacity: 1 !important;
    transform: none !important;
  }
</style>
