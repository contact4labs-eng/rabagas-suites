---
/**
 * COOKIE CONSENT — premium GDPR banner.
 *
 * 21st.dev exploration round 3:
 * - shadcnblockscom/cookie-bottom-strip — full-width footer strip. Heavy
 *   and harsh on mobile. Rejected.
 * - aceternity/floating-toast-bottom-left — close, but the floating
 *   shadow was too SaaS-y. Adapted to a flat cream card.
 * - Final choice: a bottom-left fixed card on desktop, a full-bleed
 *   bottom drawer on mobile. Cream background, warm border, two
 *   buttons (accept analytics / essential only), plus a "manage"
 *   reopener link emitted in the footer for return visitors.
 *
 * Behaviour:
 * - Hidden by default; the inline script in BaseLayout decides whether
 *   to show it based on `localStorage.rabagas-consent`.
 * - Three states stored: 'granted', 'denied', or absent (= banner shown).
 * - On 'granted', the BaseLayout analytics bootstrap (GTM + gtag) runs.
 * - On 'denied' or absent, analytics never load.
 * - Re-opening: clicking the footer "Cookie preferences" link clears
 *   the stored value and reloads, which re-shows the banner. The
 *   analytics-load is gated again on the next visit.
 *
 * No dark patterns: the two choices are visually equivalent (same size,
 * same weight). "Decline" is *not* hidden in a hamburger.
 *
 * Localized labels via t().
 */
import type { Locale } from '../../lib/i18n';
import { t } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<div
  id="cookie-consent"
  role="dialog"
  aria-modal="false"
  aria-labelledby="cookie-consent-title"
  aria-describedby="cookie-consent-body"
  aria-live="polite"
  hidden
  class="fixed inset-x-3 bottom-20 z-[110] max-w-md rounded-xl border border-sand-200 bg-cream/95 p-5 shadow-premium backdrop-blur-md md:bottom-5 md:left-5 md:right-auto md:p-6"
>
  {/* bottom-20 on mobile clears the 56px MobileBookingBar (which lives at
       bottom-0, z-50, md:hidden). Desktop uses md:bottom-5 since the
       MobileBookingBar is hidden at md+. */}
  <h2 id="cookie-consent-title" class="font-heading text-lg font-light text-ink">
    {t('consent.title', locale)}
  </h2>
  <p id="cookie-consent-body" class="mt-2 text-sm leading-relaxed text-stone-500">
    {t('consent.body', locale)}
  </p>
  {/* Mobile: flex-col with `min-h-11` so each button is ≥44px (WCAG 2.2.5
       AAA tap target). Note: `flex-1` inside a flex-col parent with no
       intrinsic height collapses children to their content height (flex-basis
       wins over `h-10`), so we drop flex-1 on mobile and only enable it on
       sm: where the row layout makes equal-width buttons meaningful. */}
  <div class="mt-5 flex flex-col gap-2 sm:flex-row">
    <button
      type="button"
      id="cookie-accept"
      class="inline-flex min-h-11 items-center justify-center rounded-none bg-ink px-5 text-[0.7rem] font-semibold uppercase tracking-[0.15em] text-cream transition-colors hover:bg-charcoal sm:h-11 sm:flex-1"
    >
      {t('consent.accept', locale)}
    </button>
    <button
      type="button"
      id="cookie-decline"
      class="inline-flex min-h-11 items-center justify-center rounded-none border border-ink bg-transparent px-5 text-[0.7rem] font-semibold uppercase tracking-[0.15em] text-ink transition-colors hover:bg-ink/5 sm:h-11 sm:flex-1"
    >
      {t('consent.decline', locale)}
    </button>
  </div>
</div>

<script>
  // Show the banner if no decision exists yet. The analytics-gating
  // decision is made by BaseLayout's inline boot script, which reads
  // the same localStorage key BEFORE this module runs.
  const KEY = 'rabagas-consent';
  const banner = document.getElementById('cookie-consent');
  const accept = document.getElementById('cookie-accept');
  const decline = document.getElementById('cookie-decline');

  // Banner uses the HTML `hidden` attribute (not the Tailwind `.hidden`
  // class) so screen readers and aria-live correctly hide/announce. Show
  // also moves keyboard focus to the Accept button for a11y. Decline
  // returns focus to whatever opened the banner (the cookie-prefs link)
  // when applicable.
  let lastFocusedTrigger: HTMLElement | null = null;
  function show() {
    if (!banner) return;
    banner.removeAttribute('hidden');
    (accept as HTMLButtonElement | null)?.focus();
  }
  function hide() {
    if (!banner) return;
    banner.setAttribute('hidden', '');
    lastFocusedTrigger?.focus();
    lastFocusedTrigger = null;
  }

  // Defer-show: avoid showing on the very first paint to keep LCP clean.
  // We give the page 800ms to settle.
  const stored = localStorage.getItem(KEY);
  if (!stored) {
    window.setTimeout(show, 800);
  }

  accept?.addEventListener('click', () => {
    localStorage.setItem(KEY, 'granted');
    hide();
    // Lazy-load analytics that BaseLayout left dormant.
    if (typeof (window as any).__bootRabagasAnalytics === 'function') {
      (window as any).__bootRabagasAnalytics();
    }
  });

  decline?.addEventListener('click', () => {
    localStorage.setItem(KEY, 'denied');
    hide();
  });

  // Allow the footer "Cookie preferences" link to re-open the banner.
  // It carries href="#cookie-preferences" and we intercept the click.
  // We capture the triggering element so hide() can return focus to it.
  document.querySelectorAll<HTMLAnchorElement>('a[data-cookie-prefs]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      lastFocusedTrigger = a;
      localStorage.removeItem(KEY);
      show();
    });
  });
</script>
