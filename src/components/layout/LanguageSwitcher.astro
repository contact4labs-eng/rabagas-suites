---
/**
 * LanguageSwitcher — three-locale display (EL · EN · FR).
 * Shows all three; the current locale is visually distinct and inert.
 * The other two link to the equivalent canonical page in their locale.
 */
import type { Locale } from '../../lib/i18n';
import { locales, getLocalizedPath, stripLocale, t } from '../../lib/i18n';

interface Props {
  locale: Locale;
  currentPath: string;
  /** "header" (compact, light-on-dark over hero) or "footer" (compact, dim-on-dark) */
  variant?: 'header' | 'footer';
}

const { locale, currentPath, variant = 'header' } = Astro.props;
const canonical = stripLocale(currentPath);

const display: Record<Locale, string> = {
  el: 'EL',
  en: 'EN',
  fr: 'FR',
};

const ariaLabels: Record<Locale, string> = {
  el: t('lang.el', locale),
  en: t('lang.en', locale),
  fr: t('lang.fr', locale),
};

const baseClass =
  variant === 'header'
    ? 'text-[0.7rem] font-medium tracking-wider'
    : 'text-xs font-medium tracking-wider';
// Phase 8 hover authorship: link-premium applies the from-center underline
// reveal (via .link-premium::after in motion.css). Inactives also bump from
// regular weight to medium on hover/focus — color shift via Tailwind token.
//
// Phase 15+: header variant tags the elements with `header-lang-*` classes
// so the global `.header-scrolled .header-lang-*` rules in Header.astro
// can flip them to dark when the header is scrolled / on light-top pages.
// Without these tags those CSS rules never matched anything (silent dead
// styles), and the switcher rendered as low-contrast white on cream.
const inactiveClass =
  variant === 'header'
    ? 'header-lang-alt link-premium text-white/60 transition-colors duration-[var(--motion-quick)] hover:text-white focus-visible:text-white'
    : 'link-premium text-stone-500 transition-colors duration-[var(--motion-quick)] hover:text-ink focus-visible:text-ink';
const activeClass =
  variant === 'header'
    ? 'header-lang-current text-white font-semibold'
    : 'text-ink font-semibold';
const sepClass = variant === 'header' ? 'header-lang-sep text-white/30' : 'text-stone-300';
---

<div class:list={['inline-flex items-center gap-1', baseClass]} aria-label={t('aria.language', locale)}>
  {locales.map((loc, i) => (
    <>
      {i > 0 && <span class:list={['mx-1', sepClass]}>·</span>}
      {loc === locale ? (
        <span class:list={[activeClass]} aria-current="true">{display[loc]}</span>
      ) : (
        <a
          href={getLocalizedPath(canonical, loc)}
          class:list={[inactiveClass]}
          hreflang={loc}
          aria-label={ariaLabels[loc]}
        >
          {display[loc]}
        </a>
      )}
    </>
  ))}
</div>
