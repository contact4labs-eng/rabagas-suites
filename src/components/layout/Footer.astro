---
import type { Locale } from '../../lib/i18n';
import { t, getLocalizedPath } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-ink px-5 pb-8 pt-20 text-stone-300 md:pt-24 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <!-- Top: brand + tagline centered -->
    <div class="mb-16 text-center">
      <a href={getLocalizedPath('/', locale)} class="inline-block" style="color: inherit; text-decoration: none;">
        <span class="block font-heading text-3xl font-light tracking-wide text-white md:text-4xl">Rabagas</span>
        <span class="label-uppercase mt-1 block text-[0.6rem] text-stone-300">{t('footer.brandTagline', locale)}</span>
      </a>
      <p class="mx-auto mt-6 max-w-sm text-sm leading-relaxed text-stone-300">
        {t('footer.tagline', locale)}
      </p>
    </div>

    <!-- Links grid -->
    <div class="grid grid-cols-2 gap-8 border-t border-white/8 pt-10 sm:grid-cols-4">
      <div>
        <h3 class="label-uppercase mb-4 text-[0.55rem] text-stone-300">{t('footer.explore', locale)}</h3>
        <ul class="flex flex-col gap-2.5">
          <li><a href={getLocalizedPath('/suites', locale)} class="link-premium text-sm text-stone-400 transition-colors hover:text-white" style="text-decoration:none;">{t('nav.suites', locale)}</a></li>
          <li><a href={getLocalizedPath('/our-story', locale)} class="link-premium text-sm text-stone-400 transition-colors hover:text-white" style="text-decoration:none;">{t('nav.story', locale)}</a></li>
          <li><a href={getLocalizedPath('/journal', locale)} class="link-premium text-sm text-stone-400 transition-colors hover:text-white" style="text-decoration:none;">{t('nav.journal', locale)}</a></li>
          <li><a href={getLocalizedPath('/contact', locale)} class="link-premium text-sm text-stone-400 transition-colors hover:text-white" style="text-decoration:none;">{t('nav.contact', locale)}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="label-uppercase mb-4 text-[0.55rem] text-stone-300">{t('footer.connect', locale)}</h3>
        <ul class="flex flex-col gap-2.5">
          <li><a href="mailto:info@rabagas-suites.gr" class="text-sm text-stone-400 transition-colors hover:text-white" style="text-decoration:none;">info@rabagas-suites.gr</a></li>
          <li><a href="tel:+302117159002" class="text-sm text-stone-400 transition-colors hover:text-white" style="text-decoration:none;">+30 211 715 9002</a></li>
        </ul>
      </div>
      <div>
        <h3 class="label-uppercase mb-4 text-[0.55rem] text-stone-300">{t('footer.social', locale)}</h3>
        <ul class="flex flex-col gap-2.5">
          <li><a href="https://www.instagram.com/rabagas.suites" target="_blank" rel="noopener noreferrer" class="link-premium text-sm text-stone-400 transition-colors hover:text-white" style="text-decoration:none;">{t('social.instagram', locale)}</a></li>
          <li><a href="https://www.facebook.com/p/Rabagas-Suites-61558497878420" target="_blank" rel="noopener noreferrer" class="link-premium text-sm text-stone-400 transition-colors hover:text-white" style="text-decoration:none;">{t('social.facebook', locale)}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="label-uppercase mb-4 text-[0.55rem] text-stone-300">{t('footer.location', locale)}</h3>
        <p class="text-sm leading-relaxed text-stone-400" set:html={t('contact.address.value', locale).replace('\n', '<br />')}></p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/5 pt-6 sm:flex-row">
      <div class="flex flex-col items-center gap-2 sm:flex-row sm:gap-5">
        <p class="text-[0.65rem] text-stone-300">&copy; {year} Rabagas Suites. {t('footer.rights', locale)}</p>
        <a href="#cookie-preferences" data-cookie-prefs class="text-[0.65rem] text-stone-400 underline-offset-2 transition-colors hover:text-stone-200 hover:underline">
          {t('footer.consent', locale)}
        </a>
      </div>
      <p class="text-[0.65rem] italic text-stone-300">{t('hero.tagline', locale)}</p>
    </div>
  </div>
</footer>
