---
/**
 * CONCIERGE INQUIRY FLOW
 * Adapted from 21st.dev: Contact Form (grouped fields with section headings)
 * + Dark Contact Section (dark bg with white form card contrast)
 * Fields grouped by intent: About You, Your Stay, Anything Else
 */
import type { Locale } from '../../lib/i18n';
import { t } from '../../lib/i18n';
import { getAllSuites } from '../../data/suites';

interface Props {
  locale: Locale;
  preselectedSuite?: string;
}

const { locale, preselectedSuite } = Astro.props;
const suites = getAllSuites();
---

<section class="bg-ink px-5 py-24 md:py-32 lg:px-8" id="booking" aria-labelledby="booking-heading">
  <div class="mx-auto max-w-xl" data-reveal="editorial">
    <!-- Header -->
    <div class="mb-10 text-center">
      <span class="label-uppercase mb-4 block text-stone-500">
        {t('booking.kicker', locale)}
      </span>
      <h2 class="font-heading text-3xl font-light text-white md:text-4xl" id="booking-heading">
        {t('booking.heading', locale)}
      </h2>
      <p class="mx-auto mt-3 max-w-sm text-sm leading-relaxed text-stone-400">
        {t('booking.intro', locale)}
      </p>
    </div>

    <!-- Form card — white on dark (21st.dev Dark Contact pattern) -->
    <form
      class="rounded-sm bg-white p-6 shadow-[0_16px_48px_rgba(0,0,0,0.15)] md:p-10"
      id="booking-form"
      action="/api/inquiry"
      method="POST"
    >
      <input type="hidden" name="form" value="booking" />
      <!-- Group 1: About you -->
      <fieldset class="space-y-4">
        <legend class="label-uppercase mb-3 text-[0.55rem] text-stone-400">
          {t('booking.group.about', locale)}
        </legend>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="flex flex-col gap-1.5">
            <label for="booking-name" class="text-xs font-medium text-stone-500">{t('contact.name', locale)}</label>
            <input type="text" id="booking-name" name="name" required autocomplete="name" placeholder={t('booking.placeholder.name', locale)} class="h-12 rounded-sm border border-sand-200 bg-cream px-4 text-base text-ink placeholder:text-stone-300 outline-none transition-colors focus:border-aegean-400 focus:ring-2 focus:ring-aegean-100" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="booking-email" class="text-xs font-medium text-stone-500">{t('contact.emailField', locale)}</label>
            <input type="email" id="booking-email" name="email" required autocomplete="email" placeholder="your@email.com" class="h-12 rounded-sm border border-sand-200 bg-cream px-4 text-base text-ink placeholder:text-stone-300 outline-none transition-colors focus:border-aegean-400 focus:ring-2 focus:ring-aegean-100" />
          </div>
        </div>
      </fieldset>

      <!-- Divider -->
      <div class="my-6 h-px bg-sand-200"></div>

      <!-- Group 2: Your stay -->
      <fieldset class="space-y-4">
        <legend class="label-uppercase mb-3 text-[0.55rem] text-stone-400">
          {t('booking.group.stay', locale)}
        </legend>
        <div class="flex flex-col gap-1.5">
          <label for="booking-suite" class="text-xs font-medium text-stone-500">
            {t('booking.suite.label', locale)}
          </label>
          <select id="booking-suite" name="suite" class="h-12 rounded-sm border border-sand-200 bg-cream px-4 text-base text-ink outline-none appearance-none transition-colors focus:border-aegean-400">
            <option value="">{t('booking.suite.undecided', locale)}</option>
            {suites.map((s) => (
              <option value={s.name.en} selected={preselectedSuite === s.id}>
                {s.name[locale]} &mdash; {s.capacity.guests}{s.capacity.extraGuests ? `+${s.capacity.extraGuests}` : ''} {t('suite.guests', locale)}
              </option>
            ))}
          </select>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="flex flex-col gap-1.5">
            <label for="booking-checkin" class="text-xs font-medium text-stone-500">{t('booking.arrival', locale)}</label>
            <input type="date" id="booking-checkin" name="checkin" class="h-12 rounded-sm border border-sand-200 bg-cream px-4 text-base text-ink outline-none transition-colors focus:border-aegean-400" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="booking-checkout" class="text-xs font-medium text-stone-500">{t('booking.departure', locale)}</label>
            <input type="date" id="booking-checkout" name="checkout" class="h-12 rounded-sm border border-sand-200 bg-cream px-4 text-base text-ink outline-none transition-colors focus:border-aegean-400" />
          </div>
        </div>
      </fieldset>

      <!-- Divider -->
      <div class="my-6 h-px bg-sand-200"></div>

      <!-- Group 3: Anything else -->
      <fieldset class="space-y-4">
        <legend class="label-uppercase mb-3 text-[0.55rem] text-stone-400">
          {t('booking.group.other', locale)}
        </legend>
        <textarea id="booking-message" name="message" rows="3" placeholder={t('booking.placeholder.message', locale)} class="min-h-24 w-full resize-y rounded-sm border border-sand-200 bg-cream px-4 py-3 text-base text-ink placeholder:text-stone-300 outline-none transition-colors focus:border-aegean-400 focus:ring-2 focus:ring-aegean-100"></textarea>
      </fieldset>

      <!-- Submit -->
      <button type="submit" class="mt-8 flex h-13 w-full items-center justify-center rounded-none bg-charcoal text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-white transition-all duration-300 hover:bg-ink hover:shadow-lg">
        {t('booking.submit', locale)}
      </button>

      <!-- Direct-book benefits -->
      <div class="mt-6 flex flex-wrap justify-center gap-x-5 gap-y-2">
        {[t('booking.benefit.bestRate', locale), t('booking.benefit.flexibleDates', locale), t('booking.benefit.welcomeBasket', locale), t('booking.benefit.concierge', locale)].map((b) => (
          <span class="flex items-center gap-1.5 text-[0.6rem] text-stone-400">
            <span class="h-1 w-1 rounded-full bg-olive-500"></span>
            {b}
          </span>
        ))}
      </div>
    </form>

    <!-- Success state -->
    <div id="booking-success" class="hidden rounded-sm bg-white p-10 text-center shadow-[0_16px_48px_rgba(0,0,0,0.15)]">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-olive-300/20">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-olive-500"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h3 class="font-heading text-2xl font-light text-ink">
        {t('booking.success.title', locale)}
      </h3>
      <p class="mt-2 text-sm text-stone-500">
        {t('booking.success.body', locale)}
      </p>
    </div>

    <!-- Error state -->
    <div id="booking-error" class="hidden rounded-sm border border-terra-300/30 bg-terra-300/5 p-6 text-center">
      <p class="text-sm text-terra-500">
        {t('booking.error.body', locale)}
      </p>
    </div>

    <!-- Fallback -->
    <div class="mt-8 text-center">
      <p class="text-sm text-stone-500">
        {t('booking.fallback', locale)}
      </p>
      <div class="mt-2 flex items-center justify-center gap-4 text-sm">
        <a href="tel:+302117159002" class="text-aegean-400 transition-colors hover:text-aegean-100" style="text-decoration:none;">+30 211 715 9002</a>
        <span class="text-stone-600">&middot;</span>
        <a href="mailto:info@rabagas-suites.gr" class="text-aegean-400 transition-colors hover:text-aegean-100" style="text-decoration:none;">info@rabagas-suites.gr</a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Validation states */
  #booking-form input:user-invalid,
  #booking-form select:user-invalid,
  #booking-form textarea:user-invalid {
    border-color: var(--color-terra-500) !important;
    box-shadow: 0 0 0 2px rgba(196, 119, 90, 0.1);
  }

  #booking-form input:user-valid:not(:placeholder-shown),
  #booking-form select:user-valid {
    border-color: var(--color-olive-500);
  }
</style>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement | null;
  const successEl = document.getElementById('booking-success');
  const errorEl = document.getElementById('booking-error');
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  const originalLabel = submitBtn?.textContent?.trim() || '';

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl?.classList.add('hidden');

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = '...';
      }

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' },
        });

        const json = await res.json();

        if (res.ok && json.ok) {
          form.style.display = 'none';
          successEl?.classList.remove('hidden');
        } else {
          const msg = json.errors?.join('. ') || 'Submission failed';
          const errText = errorEl?.querySelector('p');
          if (errText) errText.textContent = msg;
          errorEl?.classList.remove('hidden');
          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = originalLabel; }
        }
      } catch {
        errorEl?.classList.remove('hidden');
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = originalLabel; }
      }
    });
  }
</script>
