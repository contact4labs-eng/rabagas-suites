---
/**
 * GALLERY (server-rendered grid)
 * Zero React, zero hydration. Renders a responsive grid of <button>s wrapping
 * Astro <Image>. A small inline script (~20 lines) dispatches a CustomEvent
 * 'rabagas:lightbox-open' with { id, index } when a thumbnail is clicked.
 *
 * The Lightbox island in BaseLayout listens for the event and reads the
 * matching <template data-images-for={id}> JSON to know which images to show.
 *
 * Multiple Galleries can live on a single page; each must pass a unique `id`.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Locale } from '../../lib/i18n';
import { t } from '../../lib/i18n';

interface Props {
  /** Unique per page; used to register the gallery with the Lightbox island. */
  id: string;
  images: ImageMetadata[];
  /** Optional alt-text builder. Falls back to `gallery.imageAlt` template. */
  alt?: (index: number, total: number) => string;
  locale: Locale;
  /** Default 3-column desktop. Pass 4 for denser grids. */
  columns?: 2 | 3 | 4;
}

const { id, images, alt, locale, columns = 3 } = Astro.props;
const total = images.length;

const altFor = (i: number) =>
  alt
    ? alt(i, total)
    : t('gallery.imageAlt', locale)
        .replace('{n}', String(i + 1))
        .replace('{total}', String(total));

const colClass: Record<2 | 3 | 4, string> = {
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-2 sm:grid-cols-3',
  4: 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4',
};

// JSON payload for Lightbox to pick up. We pass the optimised src + width/height
// so Lightbox can render the full-quality version with correct aspect ratio.
const lightboxPayload = images.map((img) => ({
  src: img.src,
  width: img.width,
  height: img.height,
}));
---

<div class="gallery" data-gallery-id={id}>
  <ul class:list={['grid gap-2 sm:gap-3', colClass[columns]]}>
    {images.map((img, i) => (
      <li class="aspect-[4/3] overflow-hidden rounded-sm">
        <button
          type="button"
          class="group relative h-full w-full cursor-zoom-in"
          data-lightbox-id={id}
          data-index={i}
          aria-label={t('gallery.viewLarger', locale)}
        >
          <Image
            src={img}
            alt={altFor(i)}
            widths={[400, 640, 800]}
            sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
            loading="lazy"
            quality={75}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
          />
        </button>
      </li>
    ))}
  </ul>

  <!-- Payload read by Lightbox at hydration time. -->
  <template data-images-for={id} set:html={JSON.stringify(lightboxPayload)}></template>
</div>

<script>
  // Inline (component-scoped). Wires every <button> in this Gallery to the
  // 'rabagas:lightbox-open' event the Lightbox island listens for.
  document.querySelectorAll<HTMLButtonElement>('button[data-lightbox-id]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const id = btn.dataset.lightboxId!;
      const index = Number(btn.dataset.index ?? 0);
      window.dispatchEvent(
        new CustomEvent('rabagas:lightbox-open', { detail: { id, index } }),
      );
    });
  });
</script>
