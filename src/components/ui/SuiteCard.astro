---
/**
 * SUITE CARD
 * Adapted from 21st.dev: shadcnblockscom/gallery4
 * - Full-height image cards with gradient overlay (bg-[linear-gradient(...)] mix-blend-multiply)
 * - Hover zoom effect (scale-105 with 300ms transition)
 * - Absolute-positioned text over image bottom
 * - Aspect ratios: 5:4 tablet, 16:9 desktop
 * Combined with 21st.dev: preetsuthar17/card (CVA variants, modular sub-components)
 * Selected over: generic card patterns that separate image from content
 */
import { Image } from 'astro:assets';
import type { Suite } from '../../data/suites';
import type { Locale } from '../../lib/i18n';
import { t, getSuiteUrl } from '../../lib/i18n';
import { suiteCardImages } from '../../data/images';

interface Props {
  suite: Suite;
  locale: Locale;
  featured?: boolean;
}

const { suite, locale, featured = false } = Astro.props;
const href = getSuiteUrl(suite.slug, locale);
const name = suite.name[locale];
const tagline = suite.tagline[locale];
const moodLine = suite.moodLine[locale];
const shortDesc = suite.shortDescription[locale];
const bestFor = suite.bestFor[locale];
const imgSrc = suiteCardImages[suite.id];
---

<article class:list={[
  'group relative overflow-hidden rounded-xl',
  featured ? 'min-h-[28rem] md:min-h-[32rem]' : 'min-h-[24rem] md:min-h-[27rem]',
]}>
  <a href={href} class="absolute inset-0 z-10" aria-label={`${name} — ${tagline}`}>
    <span class="sr-only">{t('suite.discover', locale)} {name}</span>
  </a>

  <!-- Image layer (21st.dev gallery4 pattern: object-cover with group-hover:scale-105) -->
  <div class="absolute inset-0">
    {imgSrc ? (
      <Image
        src={imgSrc}
        alt={name}
        class="suite-card-img h-full w-full object-cover object-center"
        widths={[400, 640, 800, 1200]}
        sizes={featured ? '(max-width: 640px) 100vw, 66vw' : '(max-width: 640px) 100vw, 33vw'}
        loading="lazy"
        quality={75}
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-sand-200 to-aegean-100">
        <span class="font-heading text-5xl font-light text-white/60">{name[0]}</span>
      </div>
    )}
    <!-- Gradient overlay (21st.dev pattern: linear-gradient mix-blend-multiply) -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
  </div>

  <!-- Content overlay (21st.dev gallery4 pattern: absolute inset-x-0 bottom-0 p-6) -->
  <div class="absolute inset-x-0 bottom-0 z-[5] flex flex-col items-start p-5 text-white md:p-6">
    <!-- Badges -->
    <div class="mb-3 flex flex-wrap gap-2">
      {suite.hasJacuzzi && (
        <span class="rounded-full bg-white/20 px-3 py-0.5 text-[0.65rem] font-medium uppercase tracking-wider text-white backdrop-blur-sm">
          Jacuzzi
        </span>
      )}
      <span class="rounded-full bg-white/15 px-3 py-0.5 text-[0.65rem] font-medium tracking-wider text-white/80 backdrop-blur-sm">
        {suite.capacity.guests}{suite.capacity.extraGuests ? `+${suite.capacity.extraGuests}` : ''} {t('suite.guests', locale)}
      </span>
    </div>

    <!-- Title -->
    <h3 class="font-heading text-2xl font-light leading-tight text-white md:text-3xl">
      {name}
    </h3>
    <p class="mt-1 text-sm font-light italic text-white/60">{moodLine}</p>

    <!-- Best-for tags -->
    <div class="mt-3 flex flex-wrap gap-1.5">
      {bestFor.slice(0, 3).map((tag) => (
        <span class="rounded-full border border-white/20 px-2.5 py-0.5 text-[0.6rem] font-medium tracking-wide text-white/75">
          {tag}
        </span>
      ))}
    </div>

    <!-- CTA arrow -->
    <div class="mt-4 flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.12em] text-white/90 transition-[gap] duration-[var(--motion-quick)] ease-[var(--ease-quick)] group-hover:gap-3">
      {t('suite.discover', locale)}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-[var(--motion-quick)] ease-[var(--ease-quick)] group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </div>
  </div>
</article>

<style>
  /* Phase 8 hover authorship: image scales gently to 1.04 AND saturation
     lifts ~8%. Together they produce a "leaning into the image" feel that's
     warmer than a generic darkening overlay. Quick ease for responsiveness;
     considered duration so the effect doesn't feel snappy. */
  .suite-card-img {
    transition:
      transform var(--motion-considered) var(--ease-quick),
      filter var(--motion-considered) var(--ease-quick);
  }
  article.group:hover .suite-card-img {
    transform: scale(1.04);
    filter: saturate(1.08);
  }
  /* Keyboard focus parity — same affordance for screen readers / kbd users.
     Using :focus-visible on the wrapped <a> rather than the article since the
     anchor receives focus, not the article. */
  article.group:has(a:focus-visible) .suite-card-img {
    transform: scale(1.04);
    filter: saturate(1.08);
  }
  @media (prefers-reduced-motion: reduce) {
    .suite-card-img,
    article.group:hover .suite-card-img,
    article.group:has(a:focus-visible) .suite-card-img {
      transition: none;
      transform: none;
      filter: none;
    }
  }
</style>
