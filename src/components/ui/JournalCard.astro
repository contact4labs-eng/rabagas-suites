---
/**
 * JOURNAL CARD
 * Editorial card for the Journal index.
 *
 * 21st.dev exploration round 1:
 * - shadcnblockscom/blog15: title + 2-line description + tag-pill — too
 *   plain for a premium hospitality brand. Rejected.
 * - aceternity/glowing-blog-cards: shimmer hover effect — gimmicky;
 *   feels SaaS. Rejected.
 * - daysui/article-feature-grid: small kicker, large serif headline,
 *   2-line excerpt, fine-rule meta footer — closest to a hotel
 *   editorial voice. Adapted here.
 *
 * Output: a card with three vertical zones — meta kicker (kind +
 * publication date), large Cormorant headline, single excerpt
 * paragraph, footer-rule action. Press cards swap the "Read"
 * affordance for an "← Featured in {publication}" badge so trust is
 * visible at index-glance.
 */
import type { Locale } from '../../lib/i18n';
import { t, getJournalPostUrl } from '../../lib/i18n';

interface Props {
  locale: Locale;
  post: {
    slug: string;
    title: string;
    description: string;
    publishedAt: Date;
    kind: 'guide' | 'press';
    externalSource?: string;
    readingMinutes?: number;
  };
  featured?: boolean;
}

const { locale, post, featured = false } = Astro.props;
const href = getJournalPostUrl(post.slug, locale);
const dateLocale: Record<Locale, string> = { el: 'el-GR', en: 'en-US', fr: 'fr-FR' };
const dateLabel = new Intl.DateTimeFormat(dateLocale[locale], {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(post.publishedAt);

const kindLabel =
  post.kind === 'press'
    ? t('journal.kind.press', locale)
    : t('journal.kind.guide', locale);
---

<article
  class:list={[
    'group relative flex h-full flex-col border-t border-sand-200 pt-8',
    featured ? 'md:pt-12' : '',
  ]}
  data-journal-card
  data-kind={post.kind}
>
  <a
    href={href}
    class="absolute inset-0 z-10"
    aria-label={post.title}
    style="text-decoration:none;"
  >
    <span class="sr-only">{t('journal.read', locale)}</span>
  </a>

  <!-- Meta row: kind + date -->
  <div class="mb-4 flex items-center gap-3 text-[0.6rem] uppercase tracking-[0.18em]">
    <span
      class:list={[
        'rounded-full px-2.5 py-1 font-medium',
        post.kind === 'press'
          ? 'bg-ink text-cream'
          : 'bg-sand-100 text-stone-500',
      ]}
    >
      {kindLabel}
    </span>
    <time datetime={post.publishedAt.toISOString().slice(0, 10)} class="text-stone-400">
      {dateLabel}
    </time>
    {post.readingMinutes && (
      <span class="text-stone-300">·</span>
      <span class="text-stone-400">
        {t('journal.minRead', locale).replace('{n}', String(post.readingMinutes))}
      </span>
    )}
  </div>

  <h3
    class:list={[
      'font-heading font-light leading-[1.15] text-ink transition-colors group-hover:text-aegean-700',
      featured ? 'text-3xl md:text-4xl' : 'text-2xl md:text-[1.75rem]',
    ]}
  >
    {post.title}
  </h3>

  <p
    class:list={[
      'mt-4 flex-1 leading-[1.7] text-stone-500',
      featured ? 'text-base md:text-lg' : 'text-[0.95rem]',
    ]}
  >
    {post.description}
  </p>

  <div class="mt-6 flex items-center justify-between gap-3 border-t border-sand-100 pt-5">
    {post.kind === 'press' && post.externalSource ? (
      <span class="text-xs italic text-stone-500">
        {t('journal.featuredIn', locale)}
        <span class="ml-1 font-medium not-italic text-ink">{post.externalSource}</span>
      </span>
    ) : (
      <span class="label-uppercase text-[0.6rem] text-stone-500">
        {t('journal.read', locale)}
      </span>
    )}
    <span class="text-stone-400 transition-transform duration-300 group-hover:translate-x-1">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </span>
  </div>
</article>
