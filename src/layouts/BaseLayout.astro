---
import { getImage } from 'astro:assets';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MobileBookingBar from '../components/layout/MobileBookingBar.astro';
import CookieConsent from '../components/layout/CookieConsent.astro';
import Lightbox from '../components/ui/Lightbox.astro';
import type { Locale } from '../lib/i18n';
import { getAlternates, getLocalizedPath, stripLocale, locales } from '../lib/i18n';
import { propertyImages } from '../data/images';
import { buildHotelSchema, BCP47 } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  ogImage?: string;
  canonicalPath?: string;
  /** Open Graph type. Defaults to "website"; pages emitting Article schema
   *  (Our Story) should pass "article". */
  ogType?: 'website' | 'article';
  /** Page-specific JSON-LD blocks (BreadcrumbList, Suite, Article).
   *  BaseLayout emits the property-level Hotel block universally; pages
   *  pass their own schema objects in this array to be rendered alongside. */
  pageSchemas?: Array<Record<string, unknown>>;
  /** Override the auto-derived hreflang trio. Required for routes whose
   *  slug differs per locale (e.g. /journal/[slug] — every translation
   *  has its own slug, so the auto-derivation from `currentPath` can't
   *  guess them). Each entry's `url` must be an absolute URL. Omitting
   *  a locale removes that alternate (e.g. a post that exists only in
   *  EN should pass `[{ locale: 'en', url: ... }]`). */
  customAlternates?: Array<{ locale: Locale; url: string }>;
  /** Set to true on pages whose first section is a light (cream / white /
   *  sand) background — Suites index, Journal index/post, 404. Forwarded
   *  to Header so the wordmark + nav are readable from the first paint. */
  lightTop?: boolean;
}

const {
  title,
  description,
  locale,
  ogImage,
  canonicalPath,
  ogType = 'website',
  pageSchemas = [],
  customAlternates,
  lightTop = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonical = canonicalPath
  ? `https://rabagas-suites.com${canonicalPath}`
  : `https://rabagas-suites.com${currentPath}`;
const alternates = customAlternates ?? getAlternates(currentPath);
// x-default points to the EL variant if it exists in customAlternates,
// otherwise the auto-derived EL URL (for normal pages).
const xDefaultUrl = customAlternates
  ? (customAlternates.find((a) => a.locale === 'el')?.url
      ?? customAlternates[0]?.url
      ?? `https://rabagas-suites.com${currentPath}`)
  : `https://rabagas-suites.com${getLocalizedPath(stripLocale(currentPath), 'el')}`;
const og = ogImage || '/og-image.webp';

// OG locale codes (underscore-separated, used by Open Graph). BCP-47 variants
// for the same locales live in src/lib/schema.ts as the BCP47 map.
const ogLocaleMap: Record<Locale, string> = {
  el: 'el_GR',
  en: 'en_US',
  fr: 'fr_FR',
};

// Phase 10 — alternate OG locales (every locale except the active one).
// Helps Facebook/Twitter cluster the multilingual pages as variants of one
// canonical entity.
const ogLocaleAlternates = locales
  .filter((loc) => loc !== locale)
  .map((loc) => ogLocaleMap[loc]);

const skipLinkText: Record<Locale, string> = {
  el: 'Μετάβαση στο περιεχόμενο',
  en: 'Skip to content',
  fr: 'Aller au contenu',
};

// Phase 9 LCP image preload. The homepage's LCP candidate (after Phase 9
// font preloads) is the hero image rendered by Hero.astro at 100vw with
// widths [640, 1024, 1440, 1920]. We compute the same srcset here at
// build time via getImage() so the preload `<link>` and the rendered
// `<img>` reference identical hashed URLs — the browser's preload scanner
// picks the same variant the body img would, no double fetch.
//
// Only emit on the three homepage routes; other pages have different LCP
// candidates (suite detail uses a per-suite hero; our-story has no full-
// bleed image).
const isHomepage = currentPath === '/' || currentPath === '/en/' || currentPath === '/fr/';
const heroPreloadSrcset = isHomepage
  ? await Promise.all(
      [640, 1024, 1440, 1920].map(async (w) => {
        const img = await getImage({
          src: propertyImages.hero,
          width: w,
          format: 'webp',
          quality: 80,
        });
        return `${img.src} ${w}w`;
      }),
    ).then((parts) => parts.join(', '))
  : null;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Analytics (Phase 12): bootstrap is GATED behind cookie consent.
         The dataLayer is initialised synchronously so any pre-consent
         events queued by the page (e.g. Lightbox open) are captured —
         these stay in the buffer until/unless the user grants consent.

         Consent flow:
         - localStorage `rabagas-consent` === 'granted'  → boot immediately
           (deferred 1.5s after the `load` event so analytics JS doesn't
           compete with LCP).
         - 'denied' or absent → analytics never load. The CookieConsent
           banner asks the user; on Accept it calls
           window.__bootRabagasAnalytics() to load GTM/gtag at that point.
         - The function is exposed globally so the cookie banner module
           (and a "Cookie preferences" footer link) can re-bootstrap. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'GT-PZZMTZ9M');

      let __rabagasBooted = false;
      function bootRabagasAnalytics() {
        if (__rabagasBooted) return;
        __rabagasBooted = true;
        // GTM container
        (function(w,d,s,l,i){
          var f=d.getElementsByTagName(s)[0],
              j=d.createElement(s),
              dl=l!='dataLayer'?'&l='+l:'';
          j.async=true; j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
          f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-PM6PBJQW');
        // gtag.js for the GT-* tag (sibling to the gtag('config'…) above)
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=GT-PZZMTZ9M';
        document.head.appendChild(s);
      }
      // Exposed so the cookie banner can boot post-consent.
      window.__bootRabagasAnalytics = bootRabagasAnalytics;

      // Auto-boot only if consent already granted.
      try {
        var consent = localStorage.getItem('rabagas-consent');
        if (consent === 'granted') {
          if (document.readyState === 'complete') {
            setTimeout(bootRabagasAnalytics, 1500);
          } else {
            window.addEventListener('load', function(){
              setTimeout(bootRabagasAnalytics, 1500);
            }, { once: true });
          }
        }
      } catch (e) {
        // localStorage blocked (private mode, etc.) — silently treat as
        // declined; analytics never load.
      }
    </script>

    <title>{title}</title>

    <!-- Canonical & Alternates -->
    <link rel="canonical" href={canonical} />
    {alternates.map(({ locale: loc, url }) => (
      <link rel="alternate" hreflang={loc} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />

    <!-- Open Graph (Phase 10: og:type per page, locale alternates,
         ogImage absolute URL preferred for FB scraper compat) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={og.startsWith('http') ? og : `https://rabagas-suites.com${og}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocaleMap[locale]} />
    {ogLocaleAlternates.map((altLocale) => (
      <meta property="og:locale:alternate" content={altLocale} />
    ))}
    <meta property="og:site_name" content="Rabagas Suites" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={og.startsWith('http') ? og : `https://rabagas-suites.com${og}`} />

    <!-- Self-hosted font subsets — preload for the LCP wordmark
         (Cormorant Garamond 400) and primary body text (Inter 400).
         The @font-face declarations are INLINED below so the browser
         can associate the preloaded woff2 with the @font-face
         immediately, without waiting for the main CSS file. Phase 10:
         Greek subset for Inter is also self-hosted; Cormorant has no
         Greek subset on Google Fonts so EL headlines fall back to the
         OS serif (unchanged from the live-site behaviour). -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/cormorant-garamond-400-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-400-latin.woff2" crossorigin />
    {locale === 'el' && (
      <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-400-greek.woff2" crossorigin />
    )}
    <style is:inline>
      /* Cormorant Garamond — the same Latin woff2 covers weights 300 + 400
         (variable font internals on Google's CDN; we self-host one file
         per style and let @font-face map both weights to it). */
      @font-face {
        font-family: 'Cormorant Garamond';
        font-style: normal;
        font-weight: 300;
        font-display: swap;
        src: url('/fonts/cormorant-garamond-400-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'Cormorant Garamond';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/cormorant-garamond-400-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'Cormorant Garamond';
        font-style: italic;
        font-weight: 300;
        font-display: swap;
        src: url('/fonts/cormorant-garamond-italic-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'Cormorant Garamond';
        font-style: italic;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/cormorant-garamond-italic-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      /* Inter — the Latin woff2 covers all 3 weights (300/400/500). */
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 300;
        font-display: swap;
        src: url('/fonts/inter-400-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/inter-400-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 500;
        font-display: swap;
        src: url('/fonts/inter-400-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      /* Inter Greek subset (Phase 10) — covers Modern Greek body copy on
         EL pages. Same file serves all 3 weights via variable-font internals.
         The unicode-range mirrors Google Fonts' /* greek */ subset exactly.
         Cormorant Garamond does NOT ship a Greek subset on Google Fonts —
         Greek headlines fall back to the OS serif (Georgia or system),
         which has been the rendering on the live site since launch and
         is not changed by Phase 10. */
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 300;
        font-display: swap;
        src: url('/fonts/inter-400-greek.woff2') format('woff2');
        unicode-range: U+0370-0377, U+037A-037F, U+0384-038A, U+038C, U+038E-03A1, U+03A3-03FF;
      }
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/inter-400-greek.woff2') format('woff2');
        unicode-range: U+0370-0377, U+037A-037F, U+0384-038A, U+038C, U+038E-03A1, U+03A3-03FF;
      }
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 500;
        font-display: swap;
        src: url('/fonts/inter-400-greek.woff2') format('woff2');
        unicode-range: U+0370-0377, U+037A-037F, U+0384-038A, U+038C, U+038E-03A1, U+03A3-03FF;
      }
    </style>

    {heroPreloadSrcset && (
      <link
        rel="preload"
        as="image"
        imagesrcset={heroPreloadSrcset}
        imagesizes="100vw"
        fetchpriority="high"
      />
    )}

    {/* Phase 10: Google Fonts <link> removed entirely — all locales use
        the self-hosted Latin + Greek subsets declared above. Cormorant
        Garamond does not ship a Greek subset on Google Fonts, so EL
        Greek headlines render in the OS serif fallback (Georgia /
        system) — unchanged from the live-site rendering since launch. */}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured Data (Phase 10).
         Layer 1: Hotel block — emitted on every page for entity-consolidation
         across locale variants. Stable @id (https://rabagas-suites.com/#hotel)
         is the canonical URI. The home route adds containsPlace with the 6
         suites by @id reference.
         Layer 2: page-specific blocks (BreadcrumbList, Suite, Article) passed
         via the pageSchemas prop and rendered after the Hotel block.
         No fabricated trust: starRating, aggregateRating, checkinTime,
         checkoutTime, petsAllowed all omitted (see src/lib/schema.ts). -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(buildHotelSchema(locale, { withContainsPlace: isHomepage }))}
    />
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    {/* Phase 12.3 — GTM <noscript> iframe removed.
        The original `<iframe src="https://www.googletagmanager.com/ns.html?id=GTM-...">`
        loaded GTM unconditionally for visitors with JS disabled, bypassing
        the cookie-consent gate set up in the head <script>. We accept the
        analytics blind-spot for the (vanishingly small) no-JS audience to
        keep the consent contract honest: no Google request fires before
        the visitor explicitly accepts. If GTM-via-noscript is ever needed
        again, gate it behind a server-rendered consent cookie. */}

    <!-- Skip to content — accessibility -->
    <a href="#main-content" class="fixed left-4 top-4 z-[999] -translate-y-20 rounded-sm bg-charcoal px-4 py-2 text-sm text-white transition-transform focus:translate-y-0" style="text-decoration:none;">
      {skipLinkText[locale]}
    </a>

    <Header locale={locale} currentPath={currentPath} lightTop={lightTop} />

    <main id="main-content">
      <slot />
    </main>

    <Footer locale={locale} />
    <MobileBookingBar locale={locale} />

    <!-- Lightbox: single instance per page; activates only when a Gallery dispatches its event -->
    <Lightbox locale={locale} />

    <!-- GDPR cookie consent (Phase 12). Gates the analytics bootstrap
         in the inline head script above. -->
    <CookieConsent locale={locale} />

    <!-- Reveal Observer — triggers the motion system. Phase 9: simplified
         after ClientRouter removal — full page reloads mean the observer
         only needs to register once per document. The WeakSet guard is
         retained as a defensive no-op in case a future script triggers
         double-registration. -->
    <script>
      const seen = new WeakSet();
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
      );

      document
        .querySelectorAll('[data-reveal], [data-reveal-stagger]')
        .forEach((el) => {
          if (!seen.has(el)) {
            seen.add(el);
            observer.observe(el);
          }
        });
    </script>

    <style is:global>
      @import '../styles/global.css';
    </style>
  </body>
</html>
