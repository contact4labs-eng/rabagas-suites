---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MobileBookingBar from '../components/layout/MobileBookingBar.astro';
import Lightbox from '../components/ui/Lightbox.astro';
import type { Locale } from '../lib/i18n';
import { getAlternates, getLocalizedPath, stripLocale } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  ogImage?: string;
  canonicalPath?: string;
}

const { title, description, locale, ogImage, canonicalPath } = Astro.props;

const currentPath = Astro.url.pathname;
const canonical = canonicalPath
  ? `https://rabagas-suites.com${canonicalPath}`
  : `https://rabagas-suites.com${currentPath}`;
const alternates = getAlternates(currentPath);
const xDefaultUrl = `https://rabagas-suites.com${getLocalizedPath(stripLocale(currentPath), 'el')}`;
const og = ogImage || '/og-image.webp';

const ogLocaleMap: Record<Locale, string> = {
  el: 'el_GR',
  en: 'en_US',
  fr: 'fr_FR',
};

const skipLinkText: Record<Locale, string> = {
  el: 'Μετάβαση στο περιεχόμενο',
  en: 'Skip to content',
  fr: 'Aller au contenu',
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-PM6PBJQW');
    </script>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=GT-PZZMTZ9M"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'GT-PZZMTZ9M');
    </script>

    <title>{title}</title>

    <!-- Canonical & Alternates -->
    <link rel="canonical" href={canonical} />
    {alternates.map(({ locale: loc, url }) => (
      <link rel="alternate" hreflang={loc} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={og} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocaleMap[locale]} />
    <meta property="og:site_name" content="Rabagas Suites" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={og} />

    <!-- Fonts — preconnect + display=swap for fast LCP -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LodgingBusiness",
      "name": "Rabagas Suites",
      "description": "Heritage luxury suites in the heart of Apollonia, Sifnos, Greece",
      "url": "https://rabagas-suites.com",
      "telephone": "+302117159002",
      "email": "info@rabagas-suites.gr",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Apollonia",
        "addressLocality": "Sifnos",
        "postalCode": "84003",
        "addressCountry": "GR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 36.972574,
        "longitude": 24.72438
      },
      "priceRange": "$$$"
    })} />
  </head>
  <body>
    <!-- GTM noscript -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PM6PBJQW" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <!-- Skip to content — accessibility -->
    <a href="#main-content" class="fixed left-4 top-4 z-[999] -translate-y-20 rounded-sm bg-charcoal px-4 py-2 text-sm text-white transition-transform focus:translate-y-0" style="text-decoration:none;">
      {skipLinkText[locale]}
    </a>

    <Header locale={locale} currentPath={currentPath} />

    <main id="main-content">
      <slot />
    </main>

    <Footer locale={locale} />
    <MobileBookingBar locale={locale} />

    <!-- Lightbox: single instance per page; activates only when a Gallery dispatches its event -->
    <Lightbox locale={locale} />

    <!-- Reveal Observer — triggers motion system -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-reveal], [data-reveal-stagger]').forEach((el) => observer.observe(el));
    </script>

    <style is:global>
      @import '../styles/global.css';
    </style>
  </body>
</html>
