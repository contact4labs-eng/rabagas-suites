---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
import { t } from '../../lib/i18n';

const locale = 'el';
---

<BaseLayout
  title="\u0397 \u0399\u03C3\u03C4\u03BF\u03C1\u03AF\u03B1 \u03BC\u03B1\u03C2 — Rabagas Suites \u03A3\u03AF\u03C6\u03BD\u03BF\u03C2"
  description="\u0397 \u03B9\u03C3\u03C4\u03BF\u03C1\u03AF\u03B1 \u03C4\u03BF\u03C5 Rabagas: \u03AD\u03BD\u03B1\u03C2 \u03B1\u03BD\u03B1\u03C3\u03C4\u03B7\u03BB\u03C9\u03BC\u03AD\u03BD\u03BF\u03C2 \u03BA\u03C5\u03BA\u03BB\u03B1\u03B4\u03AF\u03C4\u03B9\u03BA\u03BF\u03C2 \u03BF\u03B9\u03BA\u03B9\u03C3\u03BC\u03CC\u03C2 \u03C3\u03C4\u03B7\u03BD \u0391\u03C0\u03BF\u03BB\u03BB\u03C9\u03BD\u03AF\u03B1, \u03A3\u03AF\u03C6\u03BD\u03BF\u03C2."
  locale={locale}
>
  <section class="story-hero">
    <div class="story-hero__bg" aria-hidden="true">
      <div class="story-hero__placeholder"></div>
      <div class="story-hero__overlay"></div>
    </div>
    <div class="container story-hero__content">
      <span class="label" style="color: rgba(255,255,255,0.7);">\u0391\u03C0\u03BF\u03BB\u03BB\u03C9\u03BD\u03AF\u03B1, \u03A3\u03AF\u03C6\u03BD\u03BF\u03C2</span>
      <h1 class="heading-display" style="color: var(--color-white); margin-top: var(--space-3);">
        {t('story.title', locale)}
      </h1>
      <p class="story-hero__subtitle">{t('story.subtitle', locale)}</p>
    </div>
  </section>

  <section class="story section">
    <div class="container container--narrow">
      <div class="story__body">
        <p class="story__lead">
          \u03A3\u03C4\u03B1 \u03C3\u03C4\u03B5\u03BD\u03AC \u03C3\u03BF\u03BA\u03AC\u03BA\u03B9\u03B1 \u03C4\u03B7\u03C2 \u0391\u03C0\u03BF\u03BB\u03BB\u03C9\u03BD\u03AF\u03B1\u03C2, \u03BB\u03AF\u03B3\u03B1 \u03B2\u03AE\u03BC\u03B1\u03C4\u03B1 \u03B1\u03C0\u03CC \u03C4\u03BF\u03BD \u03BA\u03B5\u03BD\u03C4\u03C1\u03B9\u03BA\u03CC \u03C0\u03B5\u03B6\u03CC\u03B4\u03C1\u03BF\u03BC\u03BF, \u03B2\u03C1\u03AF\u03C3\u03BA\u03B5\u03C4\u03B1\u03B9 \u03AD\u03BD\u03B1\u03C2 \u03BF\u03B9\u03BA\u03B9\u03C3\u03BC\u03CC\u03C2 \u03B1\u03C3\u03B2\u03B5\u03C3\u03C4\u03C9\u03BC\u03AD\u03BD\u03C9\u03BD \u03BA\u03C4\u03B9\u03C1\u03AF\u03C9\u03BD \u03C0\u03BF\u03C5 \u03B1\u03B3\u03BD\u03B1\u03BD\u03C4\u03B5\u03CD\u03BF\u03C5\u03BD \u03C4\u03BF \u03BD\u03B7\u03C3\u03AF \u03B5\u03B4\u03CE \u03BA\u03B1\u03B9 \u03C0\u03AC\u03BD\u03C9 \u03B1\u03C0\u03CC \u03AD\u03BD\u03B1\u03BD \u03B1\u03B9\u03CE\u03BD\u03B1.
        </p>

        <h2 class="heading-3">\u0397 \u0393\u03B5\u03B9\u03C4\u03BF\u03BD\u03B9\u03AC \u03C4\u03BF\u03C5 \u03A0\u03BF\u03B9\u03B7\u03C4\u03AE</h2>
        <p>
          \u0391\u03C5\u03C4\u03AC \u03C4\u03B1 \u03BA\u03C4\u03AF\u03C1\u03B9\u03B1 \u03C0\u03AE\u03C1\u03B1\u03BD \u03C4\u03BF \u03CC\u03BD\u03BF\u03BC\u03AC \u03C4\u03BF\u03C5\u03C2 \u03B1\u03C0\u03CC \u03C4\u03BF\u03BD \u03C0\u03B9\u03BF \u03B4\u03B9\u03AC\u03C3\u03B7\u03BC\u03BF \u03BA\u03AC\u03C4\u03BF\u03B9\u03BA\u03CC \u03C4\u03BF\u03C5\u03C2: \u03C4\u03BF\u03BD \u039A\u03BB\u03B5\u03AC\u03BD\u03B8\u03B7 \u03A4\u03C1\u03B9\u03B1\u03BD\u03C4\u03B1\u03C6\u03CD\u03BB\u03BB\u03BF\u03C5, \u03C0\u03BF\u03B9\u03B7\u03C4\u03AE \u03BA\u03B1\u03B9 \u03B4\u03B7\u03BC\u03BF\u03C3\u03B9\u03BF\u03B3\u03C1\u03AC\u03C6\u03BF \u03C4\u03BF\u03C5 1850, \u03B3\u03BD\u03C9\u03C3\u03C4\u03CC \u03C3\u03C4\u03BF \u03BD\u03B7\u03C3\u03AF \u03C9\u03C2 <em>Rabagas</em>. \u03A4\u03BF \u03C0\u03B1\u03C1\u03B1\u03C4\u03C3\u03BF\u03CD\u03BA\u03BB\u03B9 \u03C0\u03C1\u03BF\u03AE\u03BB\u03B8\u03B5 \u03B1\u03C0\u03CC \u03AD\u03BD\u03B1 \u03C0\u03C1\u03BF\u03BF\u03B4\u03B5\u03C5\u03C4\u03B9\u03BA\u03CC \u03C0\u03B5\u03C1\u03B9\u03BF\u03B4\u03B9\u03BA\u03CC \u03C0\u03BF\u03C5 \u03AF\u03B4\u03C1\u03C5\u03C3\u03B5 \u03C4\u03BF 1878.
        </p>

        <hr class="divider divider--center" style="margin-block: var(--space-10);" />

        <h2 class="heading-3">\u0391\u03C0\u03CC \u03C4\u03B7\u03BD \u039A\u03BB\u03B7\u03C1\u03BF\u03BD\u03BF\u03BC\u03B9\u03AC \u03C3\u03C4\u03B7 \u03A6\u03B9\u03BB\u03BF\u03BE\u03B5\u03BD\u03AF\u03B1</h2>
        <p>
          \u039C\u03B5 \u03C4\u03B7\u03BD \u03B1\u03BD\u03B1\u03C3\u03C4\u03AE\u03BB\u03C9\u03C3\u03B7 \u03B1\u03C5\u03C4\u03CE\u03BD \u03C4\u03C9\u03BD \u03BA\u03C5\u03BA\u03BB\u03B1\u03B4\u03AF\u03C4\u03B9\u03BA\u03C9\u03BD \u03BA\u03C4\u03B9\u03C1\u03AF\u03C9\u03BD \u03C0\u03C1\u03BF 1910, \u03B8\u03B5\u03BB\u03AE\u03C3\u03B1\u03BC\u03B5 \u03BD\u03B1 \u03C4\u03B9\u03BC\u03AE\u03C3\u03BF\u03C5\u03BC\u03B5 \u03B1\u03C5\u03C4\u03CC \u03C4\u03BF \u03C0\u03BD\u03B5\u03CD\u03BC\u03B1. \u039A\u03AC\u03B8\u03B5 \u03C3\u03BF\u03C5\u03AF\u03C4\u03B1 \u03B4\u03B9\u03B1\u03C4\u03B7\u03C1\u03B5\u03AF \u03C4\u03BF\u03C5\u03C2 \u03B1\u03C5\u03B8\u03B5\u03BD\u03C4\u03B9\u03BA\u03BF\u03CD\u03C2 \u03C3\u03BF\u03B2\u03B1\u03C4\u03B9\u03C3\u03BC\u03AD\u03BD\u03BF\u03C5\u03C2 \u03C4\u03BF\u03AF\u03C7\u03BF\u03C5\u03C2, \u03C4\u03B1 \u03C0\u03AD\u03C4\u03C1\u03B9\u03BD\u03B1 \u03BF\u03C3\u03C4\u03AC \u03C4\u03BF\u03C5 \u03BD\u03B7\u03C3\u03B9\u03BF\u03CD \u03BA\u03B1\u03B9 \u03C4\u03B7\u03BD \u03B1\u03C3\u03C5\u03BC\u03BC\u03B5\u03C4\u03C1\u03AF\u03B1 \u03C0\u03BF\u03C5 \u03BA\u03AC\u03BD\u03B5\u03B9 \u03C4\u03B7\u03BD \u03BA\u03C5\u03BA\u03BB\u03B1\u03B4\u03AF\u03C4\u03B9\u03BA\u03B7 \u03B1\u03C1\u03C7\u03B9\u03C4\u03B5\u03BA\u03C4\u03BF\u03BD\u03B9\u03BA\u03AE \u03C4\u03CC\u03C3\u03BF \u03B6\u03C9\u03BD\u03C4\u03B1\u03BD\u03AE.
        </p>
        <p>
          \u03A0\u03C1\u03BF\u03C3\u03B8\u03AD\u03C3\u03B1\u03BC\u03B5 \u03C3\u03C4\u03C1\u03CE\u03BC\u03B1\u03C4\u03B1 latex, \u03BC\u03B1\u03BE\u03B9\u03BB\u03AC\u03C1\u03B9\u03B1 \u03C0\u03BF\u03CD\u03C0\u03BF\u03C5\u03BB\u03BF\u03C5, \u03C7\u03B5\u03B9\u03C1\u03BF\u03C0\u03BF\u03AF\u03B7\u03C4\u03B1 \u03AD\u03C0\u03B9\u03C0\u03BB\u03B1, \u03C3\u03CD\u03B3\u03C7\u03C1\u03BF\u03BD\u03B7 \u03C4\u03AD\u03C7\u03BD\u03B7 \u03BA\u03B1\u03B9 \u03C0\u03C1\u03BF\u03CA\u03CC\u03BD\u03C4\u03B1 \u03C0\u03BF\u03BB\u03C5\u03C4\u03B5\u03BB\u03B5\u03AF\u03B1\u03C2 \u2014 \u03B3\u03B9\u03B1\u03C4\u03AF \u03B7 \u03C0\u03BF\u03BB\u03C5\u03C4\u03AD\u03BB\u03B5\u03B9\u03B1 \u03B4\u03B5\u03BD \u03C0\u03C1\u03AD\u03C0\u03B5\u03B9 \u03BD\u03B1 \u03B8\u03C5\u03C3\u03B9\u03AC\u03B6\u03B5\u03B9 \u03C4\u03B7\u03BD \u03B1\u03C5\u03B8\u03B5\u03BD\u03C4\u03B9\u03BA\u03CC\u03C4\u03B7\u03C4\u03B1.
        </p>

        <hr class="divider divider--center" style="margin-block: var(--space-10);" />

        <h2 class="heading-3">\u03A0\u03C1\u03BF\u03C3\u03C9\u03C0\u03B9\u03BA\u03AE \u03A5\u03C0\u03BF\u03B4\u03BF\u03C7\u03AE</h2>
        <p>
          \u03A4\u03BF Rabagas \u03B4\u03B5\u03BD \u03B5\u03AF\u03BD\u03B1\u03B9 \u03BE\u03B5\u03BD\u03BF\u03B4\u03BF\u03C7\u03B5\u03AF\u03BF. \u0395\u03AF\u03BD\u03B1\u03B9 \u03BC\u03B9\u03B1 \u03C3\u03C5\u03BB\u03BB\u03BF\u03B3\u03AE \u03C0\u03AD\u03BD\u03C4\u03B5 \u03B1\u03BD\u03B5\u03BE\u03AC\u03C1\u03C4\u03B7\u03C4\u03C9\u03BD \u03BA\u03B1\u03C4\u03BF\u03B9\u03BA\u03B9\u03CE\u03BD, \u03BA\u03B1\u03B8\u03B5\u03BC\u03AF\u03B1 \u03BC\u03B5 \u03C4\u03B7 \u03B4\u03B9\u03BA\u03AE \u03C4\u03B7\u03C2 \u03C0\u03CC\u03C1\u03C4\u03B1, \u03C4\u03BF\u03BD \u03B4\u03B9\u03BA\u03CC \u03C4\u03B7\u03C2 \u03C7\u03B1\u03C1\u03B1\u03BA\u03C4\u03AE\u03C1\u03B1 \u03BA\u03B1\u03B9 \u03C4\u03BF\u03BD \u03B4\u03B9\u03BA\u03CC \u03C4\u03B7\u03C2 \u03B5\u03BE\u03C9\u03C4\u03B5\u03C1\u03B9\u03BA\u03CC \u03BA\u03CC\u03C3\u03BC\u03BF.
        </p>
        <p>
          \u0395\u03BC\u03B5\u03AF\u03C2 \u2014 \u03BF \u0393\u03B9\u03CE\u03C1\u03B3\u03BF\u03C2 \u03BA\u03B1\u03B9 \u03B7 \u039D\u03C4\u03AF\u03BD\u03C4\u03B9 \u2014 \u03C3\u03B1\u03C2 \u03C5\u03C0\u03BF\u03B4\u03B5\u03C7\u03CC\u03BC\u03B1\u03C3\u03C4\u03B5 \u03C0\u03C1\u03BF\u03C3\u03C9\u03C0\u03B9\u03BA\u03AC. \u039C\u03BF\u03B9\u03C1\u03B1\u03B6\u03CC\u03BC\u03B1\u03C3\u03C4\u03B5 \u03C4\u03B9\u03C2 \u03B1\u03B3\u03B1\u03C0\u03B7\u03BC\u03AD\u03BD\u03B5\u03C2 \u03C4\u03B1\u03B2\u03AD\u03C1\u03BD\u03B5\u03C2, \u03C4\u03B1 \u03BC\u03C5\u03C3\u03C4\u03B9\u03BA\u03AC \u03C3\u03B7\u03BC\u03B5\u03AF\u03B1 \u03B3\u03B9\u03B1 \u03BA\u03BF\u03BB\u03CD\u03BC\u03C0\u03B9 \u03BA\u03B1\u03B9 \u03C4\u03B7\u03BD \u03B1\u03B3\u03AC\u03C0\u03B7 \u03BC\u03B1\u03C2 \u03B3\u03B9\u03B1 \u03B1\u03C5\u03C4\u03CC \u03C4\u03BF \u03BD\u03B7\u03C3\u03AF.
        </p>

        <blockquote class="story__quote">
          <p>\u0397 \u03C0\u03BF\u03BB\u03C5\u03C4\u03AD\u03BB\u03B5\u03B9\u03B1 \u03BC\u03C0\u03BF\u03C1\u03B5\u03AF \u03BD\u03B1 \u03B5\u03AF\u03BD\u03B1\u03B9 \u03B4\u03B9\u03B1\u03BA\u03C1\u03B9\u03C4\u03B9\u03BA\u03AE.</p>
        </blockquote>
      </div>
    </div>
  </section>

  <FinalCTA locale={locale} />
</BaseLayout>

<style>
  .story-hero { position: relative; min-height: 60vh; display: flex; align-items: center; color: var(--color-white); overflow: hidden; }
  .story-hero__bg { position: absolute; inset: 0; z-index: -1; }
  .story-hero__placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #6B5D4F, #3D6F87); }
  .story-hero__overlay { position: absolute; inset: 0; background: rgba(30, 27, 24, 0.35); }
  .story-hero__content { padding-block: 10rem 6rem; max-width: var(--container-md); }
  .story-hero__subtitle { font-size: var(--text-xl); font-weight: var(--weight-light); color: rgba(255, 255, 255, 0.8); margin-top: var(--space-4); font-style: italic; }
  .story__body { font-size: var(--text-md); line-height: var(--leading-relaxed); color: var(--color-text-secondary); }
  .story__body h2 { color: var(--color-ink); margin-bottom: var(--space-4); }
  .story__body p { margin-bottom: var(--space-5); }
  .story__lead { font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: var(--weight-light); line-height: var(--leading-snug); color: var(--color-ink); margin-bottom: var(--space-10) !important; }
  .story__quote { margin-block: var(--space-10); padding-left: var(--space-6); border-left: 2px solid var(--color-stone-light); }
  .story__quote p { font-family: var(--font-heading); font-size: var(--text-3xl); font-weight: var(--weight-light); font-style: italic; color: var(--color-ink); margin-bottom: 0 !important; }
</style>
