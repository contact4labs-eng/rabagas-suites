---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingInquiry from '../../components/ui/BookingInquiry.astro';
import { t } from '../../lib/i18n';
import { propertyImages } from '../../data/images';

const locale = 'el';
---

<BaseLayout
  title="\u0386\u03C6\u03B9\u03BE\u03B7 — Rabagas Suites \u03A3\u03AF\u03C6\u03BD\u03BF\u03C2"
  description="\u03A3\u03C7\u03B5\u03B4\u03B9\u03AC\u03C3\u03C4\u03B5 \u03C4\u03B7\u03BD \u03AC\u03C6\u03B9\u03BE\u03AE \u03C3\u03B1\u03C2 \u03C3\u03C4\u03BF Rabagas Suites, \u0391\u03C0\u03BF\u03BB\u03BB\u03C9\u03BD\u03AF\u03B1, \u03A3\u03AF\u03C6\u03BD\u03BF\u03C2."
  locale={locale}
>
  <section class="relative overflow-hidden bg-charcoal px-5 pb-20 pt-40 text-white md:pb-28 lg:px-8">
    <div class="absolute inset-0 opacity-15">
      <Image src={propertyImages.courtyard} alt="" class="h-full w-full object-cover" widths={[640, 1024]} sizes="100vw" quality={60} loading="eager" />
    </div>
    <div class="relative mx-auto max-w-3xl" data-reveal>
      <span class="label-uppercase mb-5 block text-stone-500">Rabagas Suites</span>
      <h1 class="font-heading text-[clamp(2.5rem,6vw,4.5rem)] font-light leading-[1.05] text-white">
        {'\u03A4\u03BF \u03C4\u03B1\u03BE\u03AF\u03B4\u03B9 \u03C3\u03B1\u03C2'}<br />{'\u03BE\u03B5\u03BA\u03B9\u03BD\u03AC \u03B5\u03B4\u03CE'}
      </h1>
      <p class="mt-5 max-w-md text-base font-light leading-[1.8] text-stone-400">
        {'\u0391\u03C0\u03CC \u03C4\u03B7\u03BD \u0391\u03B8\u03AE\u03BD\u03B1 \u03C3\u03C4\u03B7\u03BD \u03B9\u03B4\u03B9\u03C9\u03C4\u03B9\u03BA\u03AE \u03C3\u03B1\u03C2 \u03B2\u03B5\u03C1\u03AC\u03BD\u03C4\u03B1. \u0398\u03B1 \u03C3\u03B1\u03C2 \u03B2\u03BF\u03B7\u03B8\u03AE\u03C3\u03BF\u03C5\u03BC\u03B5 \u03C3\u03B5 \u03BA\u03AC\u03B8\u03B5 \u03B2\u03AE\u03BC\u03B1.'}
      </p>
    </div>
  </section>

  <section class="px-5 py-24 md:py-32 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="mb-16" data-reveal>
        <span class="label-uppercase mb-4 block text-stone-400">{'\u03A0\u03CE\u03C2 \u03BD\u03B1 \u03C6\u03C4\u03AC\u03C3\u03B5\u03C4\u03B5'}</span>
        <h2 class="font-heading text-3xl font-light text-ink md:text-4xl">{'\u03A4\u03BF \u03BD\u03B7\u03C3\u03AF \u03B5\u03AF\u03BD\u03B1\u03B9 \u03C0\u03B9\u03BF \u03BA\u03BF\u03BD\u03C4\u03AC \u03B1\u03C0\u03CC \u03CC\u03C3\u03BF \u03BD\u03BF\u03BC\u03AF\u03B6\u03B5\u03C4\u03B5'}</h2>
        <div class="mt-4 h-px w-10 bg-stone-300"></div>
      </div>
      <div class="grid grid-cols-1 gap-px overflow-hidden rounded-sm border border-sand-200 bg-sand-200 md:grid-cols-3" data-reveal-stagger>
        <div class="bg-white p-8 md:p-10">
          <span class="font-heading text-4xl font-light text-stone-300">01</span>
          <h3 class="mt-4 font-heading text-xl text-ink">{'\u03A6\u03C4\u03AC\u03C3\u03C4\u03B5 \u03C3\u03C4\u03B7 \u03A3\u03AF\u03C6\u03BD\u03BF'}</h3>
          <p class="mt-3 text-sm leading-[1.8] text-stone-500">{'\u039A\u03B1\u03B8\u03B7\u03BC\u03B5\u03C1\u03B9\u03BD\u03AC \u03B4\u03C1\u03BF\u03BC\u03BF\u03BB\u03CC\u03B3\u03B9\u03B1 \u03B1\u03C0\u03CC \u03A0\u03B5\u03B9\u03C1\u03B1\u03B9\u03AC (2,5\u20135 \u03CE\u03C1\u03B5\u03C2). \u039A\u03B1\u03BD\u03BF\u03BD\u03AF\u03B6\u03BF\u03C5\u03BC\u03B5 \u03BC\u03B5\u03C4\u03B1\u03C6\u03BF\u03C1\u03AC \u03B1\u03C0\u03CC \u03C4\u03BF \u03BB\u03B9\u03BC\u03AC\u03BD\u03B9.'}</p>
        </div>
        <div class="bg-white p-8 md:p-10">
          <span class="font-heading text-4xl font-light text-stone-300">02</span>
          <h3 class="mt-4 font-heading text-xl text-ink">{'\u03A6\u03C4\u03AC\u03C3\u03C4\u03B5 \u03C3\u03C4\u03B7\u03BD \u0391\u03C0\u03BF\u03BB\u03BB\u03C9\u03BD\u03AF\u03B1'}</h3>
          <p class="mt-3 text-sm leading-[1.8] text-stone-500">{'\u03A4\u03B1 \u03C0\u03BB\u03BF\u03AF\u03B1 \u03C6\u03C4\u03AC\u03BD\u03BF\u03C5\u03BD \u03C3\u03C4\u03BF\u03BD \u039A\u03B1\u03BC\u03AC\u03C1\u03B5\u03C2. \u0397 \u0391\u03C0\u03BF\u03BB\u03BB\u03C9\u03BD\u03AF\u03B1 \u03B1\u03C0\u03AD\u03C7\u03B5\u03B9 10 \u03BB\u03B5\u03C0\u03C4\u03AC. \u039A\u03B1\u03BD\u03BF\u03BD\u03AF\u03B6\u03BF\u03C5\u03BC\u03B5 \u03C4\u03B7 \u03BC\u03B5\u03C4\u03B1\u03C6\u03BF\u03C1\u03AC \u03C3\u03B1\u03C2.'}</p>
        </div>
        <div class="bg-white p-8 md:p-10">
          <span class="font-heading text-4xl font-light text-stone-300">03</span>
          <h3 class="mt-4 font-heading text-xl text-ink">{'\u03A0\u03B5\u03C1\u03C0\u03B1\u03C4\u03AE\u03C3\u03C4\u03B5 \u03C3\u03C4\u03B7 \u03C3\u03BF\u03C5\u03AF\u03C4\u03B1 \u03C3\u03B1\u03C2'}</h3>
          <p class="mt-3 text-sm leading-[1.8] text-stone-500">{'\u03A4\u03BF Rabagas \u03B2\u03C1\u03AF\u03C3\u03BA\u03B5\u03C4\u03B1\u03B9 \u03B4\u03AF\u03C0\u03BB\u03B1 \u03C3\u03C4\u03BF\u03BD \u03C0\u03B5\u03B6\u03CC\u03B4\u03C1\u03BF\u03BC\u03BF. \u039F \u0393\u03B9\u03CE\u03C1\u03B3\u03BF\u03C2 \u03AE \u03B7 \u039D\u03C4\u03AF\u03BD\u03C4\u03B9 \u03B8\u03B1 \u03C3\u03B1\u03C2 \u03C5\u03C0\u03BF\u03B4\u03B5\u03C7\u03C4\u03BF\u03CD\u03BD \u03C0\u03C1\u03BF\u03C3\u03C9\u03C0\u03B9\u03BA\u03AC.'}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-5 py-24 md:py-32 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="grid grid-cols-1 gap-16 md:grid-cols-[1.2fr_1fr] md:items-start">
        <div data-reveal="left">
          <span class="label-uppercase mb-4 block text-stone-400">{'\u0386\u03BC\u03B5\u03C3\u03B7 \u03B5\u03C0\u03B9\u03BA\u03BF\u03B9\u03BD\u03C9\u03BD\u03AF\u03B1'}</span>
          <h2 class="font-heading text-3xl font-light text-ink md:text-4xl">{'\u0395\u03AF\u03BC\u03B1\u03C3\u03C4\u03B5 \u03B5\u03B4\u03CE \u03B3\u03B9\u03B1 \u03B5\u03C3\u03AC\u03C2'}</h2>
          <div class="mt-4 h-px w-10 bg-stone-300"></div>
          <div class="mt-10 space-y-8">
            <div>
              <span class="label-uppercase text-[0.55rem] text-stone-400">{t('contact.phone', locale)}</span>
              <a href="tel:+302117159002" class="mt-1 block font-heading text-2xl font-light text-ink" style="text-decoration:none;">+30 211 715 9002</a>
              <p class="mt-1 text-xs text-stone-400">{'\u039A\u03B1\u03B8\u03B7\u03BC\u03B5\u03C1\u03B9\u03BD\u03AC, 09:00 \u2013 17:00'}</p>
            </div>
            <div>
              <span class="label-uppercase text-[0.55rem] text-stone-400">{t('contact.email', locale)}</span>
              <a href="mailto:info@rabagas-suites.gr" class="mt-1 block text-lg text-ink" style="text-decoration:none;">info@rabagas-suites.gr</a>
              <p class="mt-1 text-xs text-stone-400">{'\u0391\u03C0\u03B1\u03BD\u03C4\u03AC\u03BC\u03B5 \u03C3\u03B5 \u03BB\u03AF\u03B3\u03B5\u03C2 \u03CE\u03C1\u03B5\u03C2'}</p>
            </div>
            <div>
              <span class="label-uppercase text-[0.55rem] text-stone-400">{t('contact.address', locale)}</span>
              <p class="mt-1 text-base leading-relaxed text-ink">{'\u0391\u03C0\u03BF\u03BB\u03BB\u03C9\u03BD\u03AF\u03B1, \u03A3\u03AF\u03C6\u03BD\u03BF\u03C2 84003'}<br />{'\u0395\u03BB\u03BB\u03AC\u03B4\u03B1'}</p>
            </div>
          </div>
        </div>
        <div class="rounded-xl border border-sand-200 bg-cream p-8 md:p-10" data-reveal="right">
          <span class="label-uppercase mb-4 block text-stone-400">Concierge</span>
          <h3 class="font-heading text-2xl font-light text-ink">{'\u03A0\u03CE\u03C2 \u03BC\u03C0\u03BF\u03C1\u03BF\u03CD\u03BC\u03B5 \u03BD\u03B1 \u03B2\u03BF\u03B7\u03B8\u03AE\u03C3\u03BF\u03C5\u03BC\u03B5'}</h3>
          <div class="mt-6 space-y-5">
            <div class="flex gap-4">
              <span class="mt-0.5 text-stone-400"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.58 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
              <div><p class="text-sm font-medium text-ink">{'\u039C\u03B5\u03C4\u03B1\u03C6\u03BF\u03C1\u03AD\u03C2 \u03B1\u03C0\u03CC \u03BB\u03B9\u03BC\u03AC\u03BD\u03B9'}</p><p class="mt-0.5 text-xs text-stone-500">{'\u0391\u03C0\u03CC \u03C4\u03BF\u03BD \u039A\u03B1\u03BC\u03AC\u03C1\u03B5\u03C2 \u03C3\u03C4\u03B7 \u03C3\u03BF\u03C5\u03AF\u03C4\u03B1 \u03C3\u03B1\u03C2'}</p></div>
            </div>
            <div class="flex gap-4">
              <span class="mt-0.5 text-stone-400"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
              <div><p class="text-sm font-medium text-ink">{'\u039A\u03C1\u03B1\u03C4\u03AE\u03C3\u03B5\u03B9\u03C2 \u03B5\u03C3\u03C4\u03B9\u03B1\u03C4\u03BF\u03C1\u03AF\u03C9\u03BD'}</p><p class="mt-0.5 text-xs text-stone-500">{'\u039F\u03B9 \u03B1\u03B3\u03B1\u03C0\u03B7\u03BC\u03AD\u03BD\u03B5\u03C2 \u03BC\u03B1\u03C2 \u03C4\u03B1\u03B2\u03AD\u03C1\u03BD\u03B5\u03C2'}</p></div>
            </div>
            <div class="flex gap-4">
              <span class="mt-0.5 text-stone-400"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
              <div><p class="text-sm font-medium text-ink">{'\u0395\u03BD\u03BF\u03B9\u03BA\u03AF\u03B1\u03C3\u03B7 \u03B1\u03C5\u03C4\u03BF\u03BA\u03B9\u03BD\u03AE\u03C4\u03BF\u03C5'}</p><p class="mt-0.5 text-xs text-stone-500">{'\u03A3\u03C5\u03BD\u03B5\u03C1\u03B3\u03AC\u03C4\u03B5\u03C2, \u03C0\u03B1\u03C1\u03AC\u03B4\u03BF\u03C3\u03B7 \u03C3\u03B5 \u03B5\u03C3\u03AC\u03C2'}</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <BookingInquiry locale={locale} />
</BaseLayout>
