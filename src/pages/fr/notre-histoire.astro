---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
import { t } from '../../lib/i18n';
import type { Locale } from '../../lib/i18n';
import { propertyImages } from '../../data/images';

const locale: Locale = 'fr';
---

<BaseLayout
  title={t('meta.story.title', locale)}
  description={t('meta.story.description', locale)}
  locale={locale}
>
  <!-- Hero — left-aligned editorial -->
  <section class="relative flex min-h-[70vh] items-end overflow-hidden text-white">
    <div class="absolute inset-0 z-0">
      <Image src={propertyImages.courtyard} widths={[640, 1024, 1440]} sizes="100vw" quality={80} alt={t('story.heroImageAlt', locale)} class="h-full w-full object-cover object-bottom" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal/80 via-charcoal/30 to-transparent"></div>
    </div>
    <div class="relative z-10 mx-auto w-full max-w-5xl px-6 pb-16 pt-40 lg:px-8">
      <div class="max-w-lg hero-enter">
        <span class="label-uppercase mb-4 block text-white/50">{t('story.hero.kicker', locale)}</span>
        <h1 class="font-heading text-[clamp(2.5rem,6vw,4.5rem)] font-light leading-[1.05] text-white">{t('story.title', locale)}</h1>
        <p class="mt-4 text-lg font-light italic text-white/60">{t('story.subtitle', locale)}</p>
      </div>
    </div>
  </section>

  <!-- Lead — large serif statement -->
  <section class="px-5 py-24 md:py-32 lg:px-8">
    <div class="mx-auto max-w-3xl" data-reveal>
      <p class="font-heading text-[clamp(1.5rem,3vw,2.25rem)] font-light leading-[1.4] text-ink">
        {t('story.lead', locale)}
      </p>
    </div>
  </section>

  <!-- The Name — split editorial -->
  <section class="bg-white px-5 py-24 md:py-32 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2 md:items-start md:gap-20">
        <div data-reveal="left">
          <Image src={propertyImages.detail1} alt={t('story.detailImageAlt', locale)} class="aspect-[3/4] w-full rounded-sm object-cover" widths={[400, 640, 800]} sizes="(max-width: 768px) 100vw, 50vw" loading="lazy" quality={75} />
        </div>
        <div class="md:pt-16" data-reveal="right">
          <span class="label-uppercase mb-4 block text-stone-400">{t('story.name.kicker', locale)}</span>
          <h2 class="font-heading text-3xl font-light text-ink md:text-4xl">{t('story.name.h2', locale)}</h2>
          <div class="mt-4 h-px w-10 bg-stone-300"></div>
          <div class="mt-8 space-y-5 text-base leading-[1.8] text-stone-500">
            <p set:html={t('story.name.body1', locale)}></p>
            <p>{t('story.name.body2', locale)}</p>
            <p>{t('story.name.body3', locale)}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Restoration — reversed split -->
  <section class="px-5 py-24 md:py-32 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2 md:items-start md:gap-20">
        <div class="order-2 md:order-1 md:pt-16" data-reveal="left">
          <span class="label-uppercase mb-4 block text-stone-400">{t('story.restoration.kicker', locale)}</span>
          <h2 class="font-heading text-3xl font-light text-ink md:text-4xl">{t('story.restoration.h2', locale)}</h2>
          <div class="mt-4 h-px w-10 bg-stone-300"></div>
          <div class="mt-8 space-y-5 text-base leading-[1.8] text-stone-500">
            <p>{t('story.restoration.body1', locale)}</p>
            <p>{t('story.restoration.body2', locale)}</p>
          </div>
        </div>
        <div class="order-1 md:order-2" data-reveal="right">
          <Image src={propertyImages.detail2} alt={t('story.hosts.imageAlt', locale)} class="aspect-[3/4] w-full rounded-sm object-cover" widths={[400, 640, 800]} sizes="(max-width: 768px) 100vw, 50vw" loading="lazy" quality={75} />
        </div>
      </div>
    </div>
  </section>

  <!-- The Hosts — centered intimate section -->
  <section class="bg-charcoal px-5 py-24 text-white md:py-32 lg:px-8">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="label-uppercase mb-4 block text-stone-500">{t('story.hosts.kicker', locale)}</span>
      <h2 class="font-heading text-3xl font-light text-white md:text-4xl">{t('story.hosts.h2', locale)}</h2>
      <div class="mx-auto mt-4 h-px w-10 bg-white/15"></div>
      <div class="mt-8 space-y-5 text-base leading-[1.8] text-stone-300">
        <p>{t('story.hosts.body1', locale)}</p>
        <p>{t('story.hosts.body2', locale)}</p>
      </div>
      <blockquote class="mt-12 border-t border-white/10 pt-10">
        <p class="font-heading text-[clamp(1.5rem,3vw,2.25rem)] font-light italic text-white/80">
          {t('story.hosts.pullquote', locale)}
        </p>
      </blockquote>
    </div>
  </section>

  <FinalCTA locale={locale} />
</BaseLayout>
