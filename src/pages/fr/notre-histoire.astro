---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
import HostsModule from '../../components/sections/HostsModule.astro';
import { t } from '../../lib/i18n';
import type { Locale } from '../../lib/i18n';
import { propertyImages } from '../../data/images';
import { buildArticleSchema, buildBreadcrumbSchema } from '../../lib/schema';

const locale: Locale = 'fr';

// Five subsections of the essay. Each one is { kicker, body } from translation keys.
const essaySections = [
  { kicker: 'story.essay.neighbourhood.kicker', body: 'story.essay.neighbourhood.body' },
  { kicker: 'story.essay.poet.kicker',          body: 'story.essay.poet.body' },
  { kicker: 'story.essay.nickname.kicker',      body: 'story.essay.nickname.body' },
  { kicker: 'story.essay.venue.kicker',         body: 'story.essay.venue.body' },
  { kicker: 'story.essay.suites.kicker',        body: 'story.essay.suites.body' },
];

// Phase 10 SEO: Article schema + 2-level BreadcrumbList. og:type=article.
const pageSchemas = [
  buildArticleSchema(locale),
  buildBreadcrumbSchema(
    [
      { labelKey: 'nav.home', canonicalPath: '/' },
      { labelKey: 'nav.story', canonicalPath: '/our-story' },
    ],
    locale,
  ),
];
---

<BaseLayout
  title={t('meta.story.title', locale)}
  description={t('meta.story.description', locale)}
  locale={locale}
  ogType="article"
  pageSchemas={pageSchemas}
>
  <!-- Hero — left-aligned editorial -->
  <section class="relative flex min-h-[70vh] items-end overflow-hidden text-white">
    <div class="absolute inset-0 z-0">
      <Image src={propertyImages.courtyard} widths={[640, 1024, 1440]} sizes="100vw" quality={80} alt={t('story.heroImageAlt', locale)} class="h-full w-full object-cover object-bottom" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal/80 via-charcoal/30 to-transparent"></div>
    </div>
    <div class="relative z-10 mx-auto w-full max-w-5xl px-6 pb-16 pt-40 lg:px-8">
      <div class="max-w-lg hero-enter">
        <span class="label-uppercase mb-4 block text-white/50">{t('story.hero.kicker', locale)}</span>
        <h1 class="font-heading text-[clamp(2.5rem,6vw,4.5rem)] font-light leading-[1.05] text-white">{t('story.title', locale)}</h1>
        <p class="mt-4 text-lg font-light italic text-white/60">{t('story.subtitle', locale)}</p>
      </div>
    </div>
  </section>

  <!-- Essay — five editorial subsections (replaces former lead/name/restoration/hosts blocks).
       Each subsection has a small label-uppercase kicker, an h2 in Cormorant, and a single
       narrow-measure body paragraph. Generous vertical rhythm between subsections. -->
  <article class="px-5 py-24 md:py-32 lg:px-8">
    <div class="mx-auto max-w-3xl">
      {essaySections.map((s, i) => (
        <section class:list={['story-essay-subsection', i === 0 ? 'mt-0' : 'mt-20 md:mt-28']} data-reveal>
          <span class="label-uppercase mb-4 block text-stone-500">{t(s.kicker, locale)}</span>
          <div class="mt-6 h-px w-10 bg-stone-300"></div>
          <p class="mt-8 text-lg font-light leading-[1.85] text-stone-600 md:text-xl">{t(s.body, locale)}</p>
        </section>
      ))}
    </div>
  </article>

  <HostsModule locale={locale} />

  <FinalCTA locale={locale} />
</BaseLayout>
