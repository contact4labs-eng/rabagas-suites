---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SuiteCard from '../../../components/ui/SuiteCard.astro';
import BookingInquiry from '../../../components/ui/BookingInquiry.astro';
import { getAllSuites, getSuiteBySlug } from '../../../data/suites';
import { t } from '../../../lib/i18n';
import type { Locale } from '../../../lib/i18n';
import { suiteHeroImages, suiteGalleries } from '../../../data/images';
import Gallery from '../../../components/ui/Gallery.astro';
import Amenities from '../../../components/sections/Amenities.astro';
import { buildSuiteSchema, buildBreadcrumbSchema } from '../../../lib/schema';

export function getStaticPaths() {
  return getAllSuites().map((suite) => ({ params: { slug: suite.slug } }));
}

const locale: Locale = 'fr';
const { slug } = Astro.params;
const suite = getSuiteBySlug(slug!);
if (!suite) return Astro.redirect('/fr/les-suites');

const name = suite.name[locale];
const tagline = suite.tagline[locale];
const moodLine = suite.moodLine[locale];
const description = suite.description[locale];
const highlights = suite.highlights[locale];
const bestFor = suite.bestFor[locale];

const imgSrc = suiteHeroImages[suite.id];
const relatedSuites = getAllSuites().filter((s) => s.id !== suite.id).slice(0, 2);

// Per-suite object-position for art direction
const focalMap: Record<string, string> = {
  sunshine: 'object-center',
  moonshine: 'object-bottom',
  euphoria: 'object-center',
  epicure: 'object-center',
  boutique: 'object-top',
  apollonia: 'object-center',
};
const focalClass = focalMap[suite.id] || 'object-center';

// Phase 10 SEO: per-suite Suite schema + 3-level BreadcrumbList.
const pageSchemas = [
  buildSuiteSchema(suite, locale),
  buildBreadcrumbSchema(
    [
      { labelKey: 'nav.home', canonicalPath: '/' },
      { labelKey: 'nav.suites', canonicalPath: '/suites' },
      { label: name, canonicalPath: `/suites/${suite.slug}` },
    ],
    locale,
  ),
];
---

<BaseLayout
  title={`${name} — Rabagas Suites Sifnos`}
  description={suite.shortDescription[locale]}
  locale={locale}
  ogImage={imgSrc?.src}
  pageSchemas={pageSchemas}
>
  <!-- Cinematic hero — full bleed with title overlay at bottom -->
  <section class="relative min-h-[50vh] w-full overflow-hidden md:min-h-[60vh]">
    <div class="absolute inset-0">
      {imgSrc ? (
        <Image src={imgSrc} alt={name} class:list={['hero-image-animate h-full w-full object-cover', focalClass]} widths={[640, 1024, 1440]} sizes="100vw" loading="eager" quality={80} />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-sand-200 to-aegean-100">
          <span class="font-heading text-5xl font-light text-white/40">{name}</span>
        </div>
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-cream via-transparent to-black/30"></div>
    </div>

    <!-- Title overlaid at bottom, bleeding into content -->
    <div class="relative z-10 flex min-h-[50vh] items-end md:min-h-[60vh]">
      <div class="mx-auto w-full max-w-6xl px-5 pb-0 lg:px-8">
        <div class="hero-enter translate-y-8">
          <span class="label-uppercase text-white/60">{tagline}</span>
          <h1 class="mt-2 font-heading text-[clamp(2.5rem,7vw,5rem)] font-light leading-[0.95] text-ink">{name}</h1>
        </div>
      </div>
    </div>
  </section>

  <!-- Mood line + facts — editorial intro -->
  <section class="px-5 pt-10 pb-8 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-[1fr_20rem] md:gap-12 lg:grid-cols-[1fr_22rem]">
        <div data-reveal>
          <!-- Mood line — the emotional hook -->
          <p class="font-heading text-xl font-light italic leading-relaxed text-stone-500 md:text-2xl">
            {moodLine}
          </p>
          <div class="mt-6 h-px w-10 bg-stone-300"></div>

          <!-- Quick facts -->
          <div class="mt-8 flex flex-wrap gap-8">
            <div class="flex flex-col gap-1">
              <span class="font-heading text-3xl font-light text-ink">{suite.capacity.guests}{suite.capacity.extraGuests ? `+${suite.capacity.extraGuests}` : ''}</span>
              <span class="label-uppercase text-[0.55rem] text-stone-500">{t('suite.guests', locale)}</span>
            </div>
            <div class="flex flex-col gap-1">
              <span class="font-heading text-3xl font-light text-ink">{suite.bedrooms}</span>
              <span class="label-uppercase text-[0.55rem] text-stone-500">{t('suite.bedrooms', locale)}</span>
            </div>
            <div class="flex flex-col gap-1">
              <span class="font-heading text-3xl font-light text-ink">{suite.bathrooms}</span>
              <span class="label-uppercase text-[0.55rem] text-stone-500">{t('suite.bathrooms', locale)}</span>
            </div>
            {suite.hasJacuzzi && (
              <div class="flex items-end gap-2 pb-1">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-olive-500"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="label-uppercase text-[0.55rem] text-stone-500">{t('suite.jacuzzi', locale)}</span>
              </div>
            )}
          </div>
        </div>

        <!-- Booking sidebar — sticky -->
        <aside>
          <div class="sticky top-24 rounded-sm border border-sand-200 bg-white p-6 shadow-[0_4px_24px_rgba(30,27,24,0.06)] md:p-7">
            <h2 class="font-heading text-lg text-ink">{t('suite.bookThis', locale)}</h2>
            <p class="mt-2 text-xs leading-relaxed text-stone-500">
              George &amp; Didi confirm personally within hours.
            </p>
            <a
              href="#booking"
              class="mt-5 flex h-12 w-full items-center justify-center rounded-none bg-charcoal text-[0.65rem] font-semibold uppercase tracking-[0.15em] text-white transition-colors hover:bg-ink"
              style="text-decoration:none;"
            >
              {t('booking.cta', locale)}
            </a>
            <div class="my-4 flex items-center gap-3 text-xs text-stone-500">
              <span class="h-px flex-1 bg-sand-200"></span>or<span class="h-px flex-1 bg-sand-200"></span>
            </div>
            <a href="tel:+302117159002" class="block text-center text-sm font-medium text-aegean-600" style="text-decoration:none;">+30 211 715 9002</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Description + highlights — editorial flow -->
  <section class="px-5 pb-16 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl" data-reveal>
        <p class="text-lg leading-[1.8] text-stone-600">{description}</p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-12 md:grid-cols-2">
        <div data-reveal="left">
          <h2 class="label-uppercase mb-4 text-[0.6rem] text-stone-500">{t('suite.bestFor', locale)}</h2>
          <div class="flex flex-wrap gap-2">
            {bestFor.map((tag) => (
              <span class="rounded-none border border-sand-200 px-4 py-2 text-sm text-stone-600">{tag}</span>
            ))}
          </div>
        </div>
        <div data-reveal="right">
          <h2 class="label-uppercase mb-4 text-[0.6rem] text-stone-500">{t('suite.highlights', locale)}</h2>
          <ul class="flex flex-col gap-3">
            {highlights.map((h) => (
              <li class="flex items-center gap-3 text-sm text-stone-600">
                <span class="h-px w-3 bg-stone-300"></span>
                {h}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Features row -->
      <div class="mt-10 flex flex-wrap gap-6 border-t border-sand-200 pt-8">
        {suite.hasKitchen && (
          <span class="inline-flex items-center gap-2 text-xs text-stone-500">
            <span class="h-1 w-1 rounded-full bg-olive-500"></span>
            {t('suite.kitchen', locale)}
          </span>
        )}
        {suite.hasBalcony && (
          <span class="inline-flex items-center gap-2 text-xs text-stone-500">
            <span class="h-1 w-1 rounded-full bg-olive-500"></span>
            {t('suite.balcony', locale)}
          </span>
        )}
        {suite.hasPrivateYard && (
          <span class="inline-flex items-center gap-2 text-xs text-stone-500">
            <span class="h-1 w-1 rounded-full bg-olive-500"></span>
            {t('suite.yard', locale)}
          </span>
        )}
      </div>
    </div>
  </section>

  
  <!-- Suite Gallery -->
  <section class="px-5 py-16 md:py-20 lg:px-8">
    <div class="mx-auto max-w-6xl" data-reveal>
      <h2 class="label-uppercase mb-6 text-[0.6rem] text-stone-500">{t('gallery.suite.heading', locale)}</h2>
      {suiteGalleries[suite.id as keyof typeof suiteGalleries] && (
        <Gallery
          id={`suite-${suite.id}`}
          images={suiteGalleries[suite.id as keyof typeof suiteGalleries].gallery}
          locale={locale}
          columns={3}
        />
      )}
    </div>
  </section>

  <!-- Phase 9: Amenities. The settle reveal pattern (Phase 8) lands the
       icons one-by-one at a tight 60ms cadence — distinct from the
       gallery's flat reveal above and the booking form's editorial
       reveal below. -->
  <Amenities locale={locale} />

  <!-- Related -->
  <section class="bg-sand-50 px-5 py-20 md:py-24 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-10 font-heading text-2xl font-light text-ink" data-reveal>{t('suite.related', locale)}</h2>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2" data-reveal-stagger>
        {relatedSuites.map((s) => (
          <SuiteCard suite={s} locale={locale} />
        ))}
      </div>
    </div>
  </section>

  <BookingInquiry locale={locale} preselectedSuite={suite.id} />
</BaseLayout>
