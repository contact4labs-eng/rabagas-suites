---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../lib/i18n';
import Hero from '../../components/sections/Hero.astro';
import BrandStatement from '../../components/sections/BrandStatement.astro';
import ArrivalNarrative from '../../components/sections/ArrivalNarrative.astro';
import SuitesPreview from '../../components/sections/SuitesPreview.astro';
import StayExperience from '../../components/sections/StayExperience.astro';
import WhyRabagas from '../../components/sections/WhyRabagas.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import BookingInquiry from '../../components/ui/BookingInquiry.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
import Gallery from '../../components/ui/Gallery.astro';
import { propertyGallery } from '../../data/images';

const locale = 'en';
---

<BaseLayout
  title={t('meta.home.title', locale)}
  description={t('meta.home.description', locale)}
  locale={locale}
>
  <!-- 1. Arrival / Mood -->
  <Hero locale={locale} />

  <!-- 2. Signature moment — scroll-linked word reveal -->
  <BrandStatement locale={locale} />

  <!-- 3. Destination / Positioning -->
  <ArrivalNarrative locale={locale} />

  <!-- 3. Suite Discovery -->
  <SuitesPreview locale={locale} />

  <!-- 4. Lifestyle / Experience -->
  <StayExperience locale={locale} />

  <!-- 5. Heritage / Identity -->
  <!-- Property Gallery — between lifestyle and trust pivot -->
  <section class="bg-sand-50 px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-7xl" data-reveal>
      <div class="mb-10 text-center">
        <span class="label-uppercase mb-3 block text-stone-400">{t('gallery.label', locale)}</span>
        <h2 class="font-heading text-3xl font-light text-ink md:text-4xl">{t('gallery.heading', locale)}</h2>
      </div>
      <Gallery id="home" images={propertyGallery} locale={locale} columns={4} />
    </div>
  </section>

  <!-- Property Gallery -->
  <WhyRabagas locale={locale} />

  <!-- 6. Trust / Social Proof -->
  <Testimonials locale={locale} />

  <!-- 7. Conversion -->
  <BookingInquiry locale={locale} />

  <!-- 8. Emotional Close -->
  <FinalCTA locale={locale} />
</BaseLayout>
